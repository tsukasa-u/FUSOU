---
import "../assets/app.css";
import "../styles/global.css";
import FocusBehavior from "@/components/FocusBehavior.astro";
import TutorialModal from "@/components/TutorialModal.astro";

type TutorialGuide = {
  id: string;
  title: string;
  summary: string;
  steps: string[];
  controls?: Array<{
    label: string;
    description: string;
    tone?: "primary" | "outline" | "ghost";
  }>;
  buttonLabel?: string;
};

const { title = "FUSOU", tutorial = null } = Astro.props as {
  title?: string;
  tutorial?: TutorialGuide | null;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta
      name="description"
      content="FUSOU is a website designed to extract, display, analyze, and utilize data from Kantai Collection (KanColle) using a proxy server, providing innovative tools and insights for users."
    />
    {
      import.meta.env.PROD && (
        <!-- Cloudflare Web Analytics -->
        <script
          defer
          is:inline
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN}"}`}
        />
        <!-- End Cloudflare Web Analytics -->
      )
    }
  </head>
  <body>
    <FocusBehavior />
    <slot />
    {tutorial && <TutorialModal guide={tutorial} />}
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    /* scrollbar-gutter: stable; */
    scrollbar-width: none;
  }
</style>
