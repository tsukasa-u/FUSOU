---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import ShipGrowthPanel from "@/components/solid/ShipGrowthPanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - パラメータ推移"
  tutorial={{
    id: "ship-growth",
    title: "パラメータ推移ページの使い方",
    summary: "艦娘ごとの成長推移を時系列で確認できます。",
    steps: [
      "対象艦を選択してレベル・各ステータスの推移を確認します。",
      "期間や表示範囲を調整して成長傾向を比較します。",
      "結果を編成や育成方針の判断に活用します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="パラメータ推移"
      subtitle="収集された経験値テーブルと naked パラメータ成長の可視化"
    />

    <ShipGrowthPanel client:only="solid-js" />
  </PageShell>
</PageLayout>
