---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import ShipGrowthPanel from "@/components/solid/ShipGrowthPanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - パラメータ推移"
  tutorial={{
    id: "ship-growth",
    title: "パラメータ推移ページの使い方",
    summary: "艦娘ごとの成長推移を時系列で確認できます。",
    controls: [
      {
        sourceSelector: "#tutorial-open-btn",
        description:
          "この説明モーダルを再表示します。操作方法を確認したいときに利用してください。",
        tone: "primary",
      },
    ],
    steps: [
      "レベル帯ごとの naked パラメータ（素ステータス）をグラフで追い、成長率や上限値を読み取ります。",
      "期間や表示範囲を調整して複数艦娘の成長傾向を比較します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="パラメータ推移"
      subtitle="収集された経験値テーブルと naked パラメータ成長の可視化"
    />

    <ShipGrowthPanel client:only="solid-js" />
  </PageShell>
</PageLayout>
