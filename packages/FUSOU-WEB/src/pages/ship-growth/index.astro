---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import ShipGrowthPanel from "@/components/solid/ShipGrowthPanel";

export const prerender = false;
---

<PageLayout title="FUSOU - 艦成長データ">
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <div class="mb-6">
        <h1 class="text-3xl font-bold">艦成長データ</h1>
        <p class="text-base-content/60 mt-1">
          収集された経験値テーブルと naked パラメータ成長の可視化
        </p>
      </div>

      <ShipGrowthPanel client:only="solid-js" />
    </div>
  </div>
</PageLayout>
