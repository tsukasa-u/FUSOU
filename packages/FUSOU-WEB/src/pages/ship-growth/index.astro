---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import ShipGrowthPanel from "@/components/solid/ShipGrowthPanel";

export const prerender = false;
---

<PageLayout
  title="FUSOU - パラメータ推移"
  tutorial={{
    id: "ship-growth",
    title: "パラメータ推移ページの使い方",
    summary: "艦娘ごとの成長推移を時系列で確認できます。",
    steps: [
      "対象艦を選択してレベル・各ステータスの推移を確認します。",
      "期間や表示範囲を調整して成長傾向を比較します。",
      "結果を編成や育成方針の判断に活用します。",
    ],
  }}
>
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <div class="mb-6">
        <h1 class="text-3xl font-bold">パラメータ推移</h1>
        <p class="text-base-content/60 mt-1">
          収集された経験値テーブルと naked パラメータ成長の可視化
        </p>
      </div>

      <ShipGrowthPanel client:only="solid-js" />
    </div>
  </div>
</PageLayout>
