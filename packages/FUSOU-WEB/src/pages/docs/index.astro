---
import "@/assets/app.css";
import "@/styles/global.css";
import Navigation from "@/components/layout/Navigation.astro";
import LeftMenu from "@/components/docs/LeftMenu.astro";
import Layout from "@/layouts/Layout.astro";
import { compareSegments } from "@/utils/page_sorter";
import type { MarkdownInstance } from "astro";

const rawDocsGlobResult = import.meta.glob("@docs/**/*.md", {
  eager: true,
});
const rawDocs = Object.values(rawDocsGlobResult).reverse() as MarkdownInstance<
  Record<string, any>
>[];

const normalizeSlug = (value: string | undefined) =>
  (value ?? "").replace(/^\/+|\/+$/g, "").replace(/^docs\//, "");

const formatSegment = (segment: string) =>
  segment
    .split(/[-_]/g)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

const docs = rawDocs
  .map((doc) => {
    const slug = normalizeSlug(doc.frontmatter?.slug);
    const segments = slug.split("/").filter(Boolean);
    if (segments.length === 0) return null;

    return {
      slug,
      segments,
      title: doc.frontmatter?.title ?? formatSegment(segments.at(-1)!),
      description: doc.frontmatter?.description ?? "",
      url: `/docs/${slug}`,
    };
  })
  .filter(Boolean) as {
  slug: string;
  segments: string[];
  title: string;
  description: string;
  url: string;
}[];

const docsWithSchema = [
  {
    slug: "schema/api-schema-explorer",
    segments: ["schema", "api-schema-explorer"],
    title: "API Schema Explorer",
    description:
      "Interactive visualization of kc-api database tables and API endpoint structures with ReactFlow.",
    url: "/docs/api-schema",
  },
  ...docs,
];

type MenuNode = {
  title: string;
  url?: string;
  description?: string;
  children: MenuNode[];
};

const root = new Map<
  string,
  {
    segment: string;
    title: string;
    url?: string;
    description?: string;
    children: Map<string, any>;
  }
>();

for (const entry of docsWithSchema) {
  let current = root;
  entry.segments.forEach((segment, index) => {
    const isLeaf = index === entry.segments.length - 1;
    if (!current.has(segment)) {
      current.set(segment, {
        segment,
        title: isLeaf ? entry.title : formatSegment(segment),
        url: isLeaf ? entry.url : undefined,
        description: isLeaf ? entry.description : undefined,
        children: new Map(),
      });
    } else if (isLeaf) {
      const node = current.get(segment)!;
      node.title = entry.title;
      node.url = entry.url;
      node.description = entry.description;
    }
    current = current.get(segment)!.children;
  });
}

const mapToArray = (nodeMap: Map<string, any>): MenuNode[] =>
  Array.from(nodeMap.values())
    .sort((a, b) => compareSegments(a, b))
    .map((node) => ({
      title: node.title,
      url: node.url,
      description: node.description,
      children: mapToArray(node.children),
    }));

const menuTree = mapToArray(root);
const topLevelSections = menuTree.length;
const totalDocs = docsWithSchema.length;
const quickLinks = docsWithSchema.map((doc) => ({
    title: doc.title,
    description: doc.description,
    url: doc.url,
  }));
const suggestedQuickLinks = quickLinks.slice(0, 8);

const escapeHtml = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");

const sanitizeDocsUrl = (value: string | undefined): string | null => {
  if (!value || !value.startsWith("/docs/")) return null;
  const slug = value.slice("/docs/".length);
  const safeSlug = slug
    .split("/")
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join("/");
  return safeSlug ? `/docs/${safeSlug}` : "/docs";
};

const renderMenuHtml = (
  nodes: MenuNode[],
  depth: number,
  maxDepth: number,
): string =>
  nodes
    .map((node) => {
      const safeUrl = sanitizeDocsUrl(node.url);
      const label = safeUrl
        ? `<div class="space-y-${maxDepth / depth}"><a href="${escapeHtml(safeUrl)}" class="inline-flex items-center rounded-md px-1 text-lg font-semibold text-sky-600 transition-all hover:bg-sky-500/10 hover:text-sky-500 hover:underline hover:translate-x-0.5">${escapeHtml(
            node.title,
          )}</a>${
            node.description
              ? `<p class="text-sm text-base-content/70">${escapeHtml(node.description)}</p>`
              : ""
          }</div>`
        : `<span class="text-xl font-bold pl-2 tracking-wide text-base-content/80">${escapeHtml(
            node.title,
          )}</span>`;
      const children = node.children.length
        ? `<ul class="ml-3 border-base-300 pl-4 space-y-${maxDepth / depth}">${renderMenuHtml(
            node.children,
            depth * 2,
            maxDepth,
          )}</ul>`
        : "";
      return `<li class="space-y-${maxDepth / depth}">${label}${children}</li>`;
    })
    .join("");

const menuHtml = renderMenuHtml(menuTree, 2, 4);
---

<Layout>
  <div class="h-16"></div>
  <div class="flex">
    <div class="flex-1 min-w-0"></div>
    <div
      class="grid grid-cols-24 gap-x-4 sm:gap-x-6 md:gap-x-8 pt-4 max-w-[1600px] w-full px-4 sm:px-6 md:px-8"
    >
      <aside
        class="hidden md:block md:col-span-8 md:col-start-1 xl:col-span-5 xl:col-start-2 pr-4 sticky top-20 self-start h-fit"
      >
        <LeftMenu />
      </aside>

      <main
        class="py-4 px-2 sm:px-6 md:px-4 xl:px-12 col-span-24 md:col-span-16 xl:col-span-12 min-w-0"
      >
        <section class="rounded-xl border border-base-300/70 bg-base-100 p-5 sm:p-6">
          <h1 class="text-3xl font-bold text-base-content">
            Documentation Index
          </h1>
          <p class="mt-2 text-base text-base-content/80 max-w-[70ch]">
            Browse every guide, quick start, and reference entry grouped by hierarchy.
            Start from the left menu if you know the category, or jump from the links below.
          </p>
          <div class="mt-4 flex flex-wrap gap-2 text-sm">
            <span class="rounded-full border border-base-300 px-3 py-1 text-base-content/75">{totalDocs} documents</span>
            <span class="rounded-full border border-base-300 px-3 py-1 text-base-content/75">{topLevelSections} top-level sections</span>
          </div>
        </section>
        <ul class="mt-6 bg-base-100 rounded-xl border border-base-300/70 py-6 px-4 sm:px-6 space-y-8" set:html={menuHtml} />
      </main>

      <aside
        class="hidden xl:block xl:col-span-5 pl-4 sticky top-20 self-start h-fit"
      >
        <div class="max-h-[calc(100vh-9.5rem)] pr-2">
          <section class="rounded-xl border border-base-300/70 bg-base-100 p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h2 class="text-base font-semibold text-base-content">Quick search</h2>
              <span id="docs-search-hint" class="text-xs text-base-content/60">Suggested pages</span>
            </div>
            <label class="input input-bordered mt-3 flex items-center gap-2 w-full">
              <span class="text-base-content/55">Search</span>
              <input
                id="docs-search-input"
                type="text"
                class="grow"
                placeholder="e.g. auth, battle, schema"
              />
            </label>
            <ul id="docs-quick-links" class="mt-3 space-y-2 max-h-[calc(100vh-18rem)] overflow-y-auto pr-1">
              {
                quickLinks.map((item) => (
                  <li
                    data-doc-item
                    data-title={item.title.toLowerCase()}
                    data-description={item.description.toLowerCase()}
                    data-suggested={suggestedQuickLinks.some((suggested) => suggested.url === item.url) ? "true" : "false"}
                  >
                    <a href={item.url} class="block rounded-lg border border-base-300/70 bg-base-100 px-3 py-2 hover:bg-base-200/60 transition-colors">
                      <p class="text-sm font-semibold text-base-content">{item.title}</p>
                      {item.description && (
                        <p class="text-xs text-base-content/65 mt-0.5 line-clamp-2">{item.description}</p>
                      )}
                    </a>
                  </li>
                ))
              }
            </ul>
            <p id="docs-search-empty" class="hidden mt-2 text-sm text-base-content/65">No matches found.</p>
          </section>
        </div>
      </aside>
    </div>
    <div class="flex-1 min-w-0"></div>
  </div>
  <Navigation />
</Layout>

<script is:inline>
  const input = document.getElementById("docs-search-input");
  const hint = document.getElementById("docs-search-hint");
  const items = Array.from(document.querySelectorAll("[data-doc-item]"));
  const empty = document.getElementById("docs-search-empty");

  const updateFilter = () => {
    const q = (input?.value || "").trim().toLowerCase();
    const hasQuery = q.length > 0;
    if (hint) {
      hint.textContent = hasQuery ? "Matching results" : "Suggested pages";
    }
    let visible = 0;
    items.forEach((item) => {
      const t = item.getAttribute("data-title") || "";
      const d = item.getAttribute("data-description") || "";
      const isSuggested = item.getAttribute("data-suggested") === "true";
      const match = hasQuery ? t.includes(q) || d.includes(q) : isSuggested;
      item.classList.toggle("hidden", !match);
      if (match) visible += 1;
    });
    if (empty) {
      empty.classList.toggle("hidden", !hasQuery || visible > 0);
    }
  };

  input?.addEventListener("input", updateFilter);
  updateFilter();
</script>
