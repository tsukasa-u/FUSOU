---
import "@/assets/app.css";
import "@/styles/global.css";
import Navigation from "@/components/Navigation.astro";
import Layout from "@/layouts/Layout.astro";
import SchemaGraph from "@/components/react/SchemaGraph";
---

<Layout
  title="API Schema | FUSOU"
  tutorial={{
    id: "docs-api-schema",
    title: "API Schema Explorerの使い方",
    summary: "テーブルとAPIエンドポイントの関連を視覚的に確認できます。",
    controls: [
      {
        label: "ノード選択",
        description: "対象テーブルやエンドポイントの詳細を確認します。",
        tone: "outline",
      },
      {
        label: "ズーム/パン",
        description: "グラフ全体の位置と拡大率を調整します。",
        tone: "ghost",
      },
      {
        label: "操作説明",
        description: "この説明モーダルを再表示します。",
        tone: "primary",
      },
    ],
    steps: [
      "興味のあるノードをクリックして関連情報を確認します。",
      "接続線をたどって依存関係や入出力の流れを把握します。",
      "ズームとパンで全体構造と局所詳細を行き来します。",
    ],
  }}
>
  <div class="h-16"></div>
  <div class="flex max-w-[1440px] mx-auto">
    <div class="flex-1 min-w-0"></div>
    <div class="w-full max-w-[1440px] px-4 sm:px-6 md:px-8 lg:px-12 pt-4">
      <header class="mb-4">
        <h1 class="text-2xl font-bold text-base-content">
          kc-api Schema Explorer
        </h1>
        <p class="mt-1 text-sm text-base-content/60">
          Interactive visualization of database tables and API endpoint
          structures, version by version.
        </p>
      </header>
      <SchemaGraph client:only="react" />
    </div>
    <div class="flex-1 min-w-0"></div>
  </div>
  <Navigation />
</Layout>
