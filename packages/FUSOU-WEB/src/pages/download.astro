                ></path>
              </svg>
            </div>
            <div id="hero-icon-unknown" class="hidden">
              <svg
                class="w-12 h-12 text-base-content"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
          </div>

          <div class="flex flex-col gap-1.5 w-full text-left">
            <h2
              id="hero-title"
              class="text-2xl font-semibold text-base-content"
            >
              Detecting OS...
            </h2>
            <p id="hero-sub" class="text-sm text-base-content/70">
              Please wait while we find the best installer.
            </p>
          </div>
        </div>

          <a
            id="hero-btn"
            href={releasePage}
            class="btn btn-lg w-full bg-primary hover:bg-primary/90 text-primary-content border border-primary-content/45 transition-all flex items-center justify-center gap-2 font-semibold text-base rounded-lg h-14"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
            <span id="hero-btn-text">Go to Releases</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Flat List of All Platforms (No tabs/clicks needed) -->
    <section
      class="flex flex-col gap-6 mt-12 pb-24 relative z-10 border-t border-base-300 pt-16 max-w-5xl mx-auto w-full px-4 xl:px-0"
    >
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-2"
      >
        <div class="text-left">
          <h3 class="text-2xl font-semibold text-base-content">
            Other Platforms & Architectures
          </h3>
          <p class="text-sm text-base-content/70 mt-2">
            Looking for a different version? Download installers for all
            supported operating systems below.
          </p>
        </div>
        <a
          href={releasePage}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline border-base-300 hover:border-base-content/50 gap-2 shrink-0"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
          View GitHub Releases
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Windows Flat Card -->
        <div
          class="fusou-card bg-base-100/60 border border-base-300 hover:border-base-content/20 transition-colors rounded-xl p-6 flex flex-col gap-4"
        >
          <div class="flex items-center gap-3 border-b border-base-300 pb-4">
            <svg
              class="w-6 h-6 text-info"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 448 512"
              fill="currentColor"
            >
              <path
                d="M0 93.7l183.6-25.3v177.4H0V93.7zm0 324.6l183.6 25.3V268.4H0v149.9zm203.8 28L448 480V268.4H203.8v177.9zm0-380.6v180.1H448V32L203.8 65.7z"
              ></path>
            </svg>
            <h4 class="text-lg font-semibold text-base-content">Windows</h4>
          </div>
          <div class="flex flex-col gap-3 pt-2">
            <a
              href={`${releaseBase}/fusou-windows-x64.msi`}
              class="flex items-start gap-2 group"
            >
              <div
                class="w-1.5 h-1.5 rounded-full bg-primary mt-2 group-hover:scale-150 transition-transform"
              >
              </div>
              <div class="flex flex-col">
                <span
                  class="text-sm font-medium text-base-content group-hover:text-primary transition-colors"
                  >MSI Installer (x64)</span
                >
                <span class="text-xs text-base-content/60"
                  >Recommended. Auto-updates.</span
                >
              </div>
            </a>
            <a
              href={`${releaseBase}/fusou-windows-x64.exe`}
              class="text-sm text-base-content/70 hover:text-base-content transition-colors pl-3.5"
              >EXE Installer (x64)</a
            >
            <a
              href={`${releaseBase}/fusou-windows-arm64.msi`}
              class="text-sm text-base-content/70 hover:text-base-content transition-colors pl-3.5"
              >MSI Installer (ARM64)</a
            >
            <a
              href={`${releaseBase}/fusou-windows-arm64.exe`}
              class="text-sm text-base-content/70 hover:text-base-content transition-colors pl-3.5"
              >EXE Installer (ARM64)</a
            >
          </div>
        </div>

        <!-- macOS Flat Card -->
        <div
          class="fusou-card bg-base-100/60 border border-base-300 hover:border-base-content/20 transition-colors rounded-xl p-6 flex flex-col gap-4"
        >
          <div class="flex items-center gap-3 border-b border-base-300 pb-4">
            <svg
              class="w-6 h-6 text-base-content"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 384 512"
              fill="currentColor"
            >
              <path
                d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"
              ></path>
            </svg>
            <h4 class="text-lg font-semibold text-base-content">macOS</h4>
          </div>
          <div class="flex flex-col gap-3 pt-2">
            <div class="p-3 bg-base-200/50 border border-base-300 rounded-lg">
              <span class="text-xs text-base-content/80 block leading-relaxed">
                macOS builds are not yet available. Future universal DMG builds
                will be distributed on GitHub Releases.
              </span>
            </div>
            <a
              href={releasePage}
              class="text-sm text-info hover:text-base-content transition-colors pl-1"
              >Check GitHub Releases</a
            >
          </div>
        </div>

        <!-- Linux Flat Card -->
        <div
          class="fusou-card bg-base-100/60 border border-base-300 hover:border-base-content/20 transition-colors rounded-xl p-6 flex flex-col gap-4"
        >
          <div class="flex items-center gap-3 border-b border-base-300 pb-4">
            <svg
              class="w-6 h-6 text-warning"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
