  <script define:vars={{ downloadData }}>
    // Auto-detect OS logic
    function detectOS() {
      const platform = navigator.platform.toLowerCase();
      const userAgent = navigator.userAgent.toLowerCase();

      if (platform.includes("win") || userAgent.includes("windows"))
        return "windows";
      if (platform.includes("mac") || userAgent.includes("mac os"))
        return "macos";
      if (
        platform.includes("linux") ||
        userAgent.includes("ubuntu") ||
        userAgent.includes("debian")
      )
        return "linux";
      return "unknown";
    }

    const osKey = detectOS();
    const osInfo = downloadData[osKey] || downloadData.unknown;

    // Update Hero UI
    const title = document.getElementById("hero-title");
    const sub = document.getElementById("hero-sub");
    const btnText = document.getElementById("hero-btn-text");
    const btn = document.getElementById("hero-btn");

    // Toggle exact OS SVG
    const iWin = document.getElementById("hero-icon-windows");
    const iMac = document.getElementById("hero-icon-macos");
    const iLin = document.getElementById("hero-icon-linux");
    const iUnk = document.getElementById("hero-icon-unknown");

    if (iWin) iWin.classList.add("hidden");
    if (iMac) iMac.classList.add("hidden");
    if (iLin) iLin.classList.add("hidden");
    if (iUnk) iUnk.classList.add("hidden");

    if (osKey === "windows" && iWin) iWin.classList.remove("hidden");
    else if (osKey === "macos" && iMac) iMac.classList.remove("hidden");
    else if (osKey === "linux" && iLin) iLin.classList.remove("hidden");
    else if (iUnk) iUnk.classList.remove("hidden");

    if (title) title.textContent = osInfo.name;
    if (sub) sub.textContent = osInfo.sub;
    if (btnText) btnText.textContent = osInfo.label;

    if (btn) {
      btn.href = osInfo.url;
      // If macOS is not available yet, change btn style to secondary
      if (osKey === "macos") {
        btn.classList.remove("bg-primary", "text-primary-content");
        btn.classList.add(
          "btn-outline",
          "text-base-content",
          "border-base-300",
        );
        btnText.textContent = "Check GitHub Releases";
      }
    }
  </script>
