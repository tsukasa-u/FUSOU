---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import QuestTreePanel from "@/components/solid/QuestTreePanel";

export const prerender = false;
---

<PageLayout
  title="FUSOU - クエストツリー"
  tutorial={{
    id: "quests-tree",
    title: "クエストツリーページの使い方",
    summary: "クエストの依存関係をグラフで追跡できます。",
    steps: [
      "ノードを選択して前提クエストと後続クエストを確認します。",
      "条件表示を切り替えて達成ルートを整理します。",
      "必要な進行順を把握して攻略計画に活用します。",
    ],
  }}
>
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <div class="mb-6">
        <h1 class="text-3xl font-bold">クエスト依存ツリー</h1>
        <p class="text-base-content/60 mt-1">
          収集データからマイニングされたクエスト達成条件ルールの可視化
        </p>
      </div>

      <QuestTreePanel client:only="solid-js" />
    </div>
  </div>
</PageLayout>
