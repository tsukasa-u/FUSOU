---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import QuestTreePanel from "@/components/solid/QuestTreePanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - クエストツリー"
  tutorial={{
    id: "quests-tree",
    title: "クエストツリーページの使い方",
    summary: "クエストの依存関係をグラフで追跡できます。",
    steps: [
      "ノードを選択して前提クエストと後続クエストを確認します。",
      "条件表示を切り替えて達成ルートを整理します。",
      "必要な進行順を把握して攻略計画に活用します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="クエスト依存ツリー"
      subtitle="収集データからマイニングされたクエスト達成条件ルールの可視化"
    />

    <QuestTreePanel client:only="solid-js" />
  </PageShell>
</PageLayout>
