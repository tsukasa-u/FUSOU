---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import { createSupabaseServerClient } from "@/utility/supabaseServer";
import type { User } from "@supabase/supabase-js";

const cookies = Astro.cookies;
const runtimeEnv = (Astro.locals as any)?.runtime?.env || {};
const supabase = createSupabaseServerClient(cookies, runtimeEnv);

const accessToken = cookies.get("sb-access-token");
const refreshToken = cookies.get("sb-refresh-token");

if (!accessToken || !refreshToken) {
  return Astro.redirect("/auth/signin");
}

let user: User | null = null;
try {
  const session = await supabase.auth.setSession({
    refresh_token: refreshToken.value,
    access_token: accessToken.value,
  });
  if (session.error) {
    return Astro.redirect("/auth/signin");
  }
  user = session.data.user;
} catch (_error) {
  return Astro.redirect("/auth/signin");
}

if (!user) {
  return Astro.redirect("/auth/signin");
}
---

<Layout title="API Keys - FUSOU">
  <div class="min-h-screen flex flex-col">
    <div class="flex justify-center flex-1 py-8">
      <div class="w-full max-w-2xl px-4">
        <div class="bg-base-100 rounded-md p-6">
          <div class="h-32"></div>
          <h1 class="text-2xl font-bold text-center py-2">
            API Key Management
          </h1>
          <p class="text-sm text-center text-base-content/70 mb-6">
            Manage your API keys for fusou-datasets
          </p>

          <!-- API Keys Section -->
          <div class="mb-8">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-semibold">Your API Keys</h2>
              <button
                id="create-key-btn"
                class="btn btn-sm btn-primary border border-primary-content"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M12 5v14M5 12h14"></path>
                </svg>
                Create New Key
              </button>
            </div>

            <div id="api-keys-list" class="space-y-2">
              <div class="text-center py-4 text-base-content/60">
                Loading...
              </div>
            </div>
          </div>

          <!-- New Key Display (hidden by default) -->
          <div
            id="new-key-display"
            class="hidden mb-8 p-4 bg-success/10 border border-success rounded-md"
          >
            <div class="flex items-center gap-2 mb-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="size-5 text-success"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span class="font-semibold text-success">API Key Created</span>
            </div>
            <p class="text-sm text-base-content/70 mb-2">
              Copy this key now. It will not be shown again.
            </p>
            <div class="flex gap-2">
              <code
                id="new-key-value"
                class="flex-1 bg-base-300 px-3 py-2 rounded text-sm font-mono break-all"
              ></code>
              <button
                id="copy-key-btn"
                class="btn btn-sm btn-ghost border border-base-300"
              >
                <!-- Copy icon -->
                <svg
                  id="copy-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                  ></path>
                </svg>
                <!-- Check icon (hidden by default) -->
                <svg
                  id="check-icon"
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4 hidden text-success"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Trusted Devices Section -->
          <div class="mb-8">
            <h2 class="text-lg font-semibold mb-4">Trusted Devices</h2>
            <p class="text-sm text-base-content/60 mb-4">
              Devices that have been verified for API access
            </p>

            <div id="devices-list" class="space-y-2">
              <div class="text-center py-4 text-base-content/60">
                Loading...
              </div>
            </div>
          </div>

          <div class="divider"></div>

          <!-- Back to Dashboard -->
          <div class="text-center">
            <a href="/dashboard" class="btn btn-ghost border border-base-300">
              ← Back to Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>
    <Navigation />
  </div>

  <!-- Delete Confirmation Modal -->
  <dialog id="delete-modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Confirm Deletion</h3>
      <p class="py-4" id="delete-modal-message">
        Are you sure you want to delete this item?
      </p>
      <div class="modal-action">
        <button class="btn border border-base-300" id="delete-modal-cancel"
          >Cancel</button
        >
        <button
          class="btn btn-error border border-error-content"
          id="delete-modal-confirm">Delete</button
        >
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</Layout>

<script define:vars={{ accessToken: accessToken?.value }}>
  const API_BASE = "/api/api-keys";

  // Modal state
  let pendingDeleteAction = null;

  // Modal helper
  function showDeleteModal(message, onConfirm) {
    const modal = document.getElementById("delete-modal");
    document.getElementById("delete-modal-message").textContent = message;
    pendingDeleteAction = onConfirm;
    modal.showModal();
  }

  function hideNewKeyDisplay() {
    document.getElementById("new-key-display").classList.add("hidden");
  }

  async function fetchApiKeys() {
    try {
      const response = await fetch(API_BASE, {
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });
      const data = await response.json();
      if (data.success) {
        renderApiKeys(data.api_keys);
      } else {
        document.getElementById("api-keys-list").innerHTML =
          '<div class="text-center py-4 text-error">Failed to load API keys</div>';
      }
    } catch (error) {
      document.getElementById("api-keys-list").innerHTML =
        '<div class="text-center py-4 text-error">Failed to load API keys</div>';
    }
  }

  async function fetchDevices() {
    try {
      const response = await fetch(`${API_BASE}/devices`, {
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });
      const data = await response.json();
      if (data.success) {
        renderDevices(data.devices);
      } else {
        document.getElementById("devices-list").innerHTML =
          '<div class="text-center py-4 text-error">Failed to load devices</div>';
      }
    } catch (error) {
      document.getElementById("devices-list").innerHTML =
        '<div class="text-center py-4 text-error">Failed to load devices</div>';
    }
  }

  function renderApiKeys(keys) {
    const container = document.getElementById("api-keys-list");
    if (keys.length === 0) {
      container.innerHTML = `
        <div class="text-center py-4 text-base-content/60">
          No API keys yet. Create one to get started.
        </div>`;
      return;
    }

    container.innerHTML = keys
      .map(
        (key) => `
      <div class="flex items-center justify-between p-3 bg-base-200 rounded-md" data-key-id="${escapeHtml(key.id)}">
        <div class="flex-1 min-w-0">
          <div class="text-sm text-base-content/60 font-mono">${escapeHtml(key.key_masked)}</div>
          <div class="text-xs text-base-content/40">
            ${key.is_active ? "✓ Active" : "✗ Inactive"} · 
            Created ${escapeHtml(formatDate(key.created_at))}
          </div>
        </div>
        <button 
          class="btn btn-sm btn-ghost btn-error border border-error-content delete-key-btn" 
          data-key-id="${escapeHtml(key.id)}"
          title="Delete API Key"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path>
          </svg>
        </button>
      </div>
    `
      )
      .join("");

    // Attach delete handlers
    container.querySelectorAll(".delete-key-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const keyId = e.currentTarget.dataset.keyId;
        showDeleteModal(
          "Are you sure you want to delete this API key? This action cannot be undone.",
          () => deleteApiKey(keyId)
        );
      });
    });
  }

  function renderDevices(devices) {
    const container = document.getElementById("devices-list");
    if (devices.length === 0) {
      container.innerHTML = `
        <div class="text-center py-4 text-base-content/60">
          No trusted devices yet.
        </div>`;
      return;
    }

    container.innerHTML = devices
      .map(
        (device) => `
      <div class="flex items-center justify-between p-3 bg-base-200 rounded-md" data-device-id="${escapeHtml(device.id)}">
        <div class="flex-1 min-w-0">
          <div class="font-medium">${escapeHtml(device.device_name)}</div>
          <div class="text-sm text-base-content/60 font-mono">${escapeHtml(device.client_id_masked)}</div>
          <div class="text-xs text-base-content/40">
            Added ${escapeHtml(formatDate(device.created_at))}
            ${device.last_used_at ? ` · Last used ${escapeHtml(formatDate(device.last_used_at))}` : ""}
          </div>
        </div>
        <button 
          class="btn btn-sm btn-ghost btn-error border border-error-content revoke-device-btn" 
          data-device-id="${escapeHtml(device.id)}"
          title="Revoke Device"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    `
      )
      .join("");

    // Attach revoke handlers
    container.querySelectorAll(".revoke-device-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const deviceId = e.currentTarget.dataset.deviceId;
        showDeleteModal(
          "Are you sure you want to revoke this device? It will need to be re-verified.",
          () => revokeDevice(deviceId)
        );
      });
    });
  }

  async function createApiKey() {
    try {
      const response = await fetch(API_BASE, {
        method: "POST",
        headers: {
          Authorization: `Bearer ${accessToken}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({}),
      });
      const data = await response.json();
      if (data.success) {
        // Show the new key
        const display = document.getElementById("new-key-display");
        const keyValue = document.getElementById("new-key-value");
        keyValue.textContent = data.api_key.key;
        display.classList.remove("hidden");

        // Refresh the list
        await fetchApiKeys();
      }
    } catch (error) {
      console.error("Failed to create API key", error);
    }
  }

  async function deleteApiKey(keyId) {
    try {
      const response = await fetch(`${API_BASE}/${keyId}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });
      const data = await response.json();
      if (data.success) {
        hideNewKeyDisplay();
        await fetchApiKeys();
      }
    } catch (error) {
      console.error("Failed to delete API key", error);
    }
  }

  async function revokeDevice(deviceId) {
    try {
      const response = await fetch(`${API_BASE}/devices/${deviceId}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${accessToken}`,
        },
      });
      const data = await response.json();
      if (data.success) {
        await fetchDevices();
      }
    } catch (error) {
      console.error("Failed to revoke device", error);
    }
  }

  function escapeHtml(text) {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function formatDate(dateStr) {
    if (!dateStr) return "N/A";
    const date = new Date(dateStr);
    return date.toLocaleDateString("ja-JP", {
      year: "numeric",
      month: "short",
      day: "numeric",
    });
  }

  // Initialize
  document.addEventListener("DOMContentLoaded", () => {
    fetchApiKeys();
    fetchDevices();

    // Create key button
    document
      .getElementById("create-key-btn")
      .addEventListener("click", createApiKey);

    // Copy key button - switch to check icon on success
    document.getElementById("copy-key-btn").addEventListener("click", () => {
      const key = document.getElementById("new-key-value").textContent;
      const copyIcon = document.getElementById("copy-icon");
      const checkIcon = document.getElementById("check-icon");

      navigator.clipboard.writeText(key).then(() => {
        // Switch icons
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");

        // Switch back after 2 seconds
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      });
    });

    // Modal handlers
    document
      .getElementById("delete-modal-cancel")
      .addEventListener("click", () => {
        document.getElementById("delete-modal").close();
        pendingDeleteAction = null;
      });

    document
      .getElementById("delete-modal-confirm")
      .addEventListener("click", async () => {
        document.getElementById("delete-modal").close();
        if (pendingDeleteAction) {
          await pendingDeleteAction();
          pendingDeleteAction = null;
        }
      });
  });
</script>
