---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";

export const prerender = false;
---

<PageLayout title="FUSOU - Battles">
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4">
        <div>
          <h1 class="text-3xl font-bold">戦闘データ</h1>
          <p class="text-base-content/60 mt-1">R2に保存された戦闘履歴を閲覧・分析</p>
        </div>
        <div class="flex gap-2">
          <a href="/battles/map-flow" class="btn btn-outline btn-sm">マップ進行</a>
          <a href="/battles/stats" class="btn btn-outline btn-sm">統計</a>
        </div>
      </div>

      <!-- Filters -->
      <div class="card bg-base-100 shadow-sm mb-6">
        <div class="card-body p-4">
          <div class="flex flex-wrap gap-4 items-end" id="battle-filters">
            <div class="form-control">
              <label class="label"><span class="label-text">期間</span></label>
              <select id="filter-period" class="select select-bordered select-sm">
                <option value="latest">最新</option>
                <option value="all">全期間</option>
              </select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">マップ</span></label>
              <select id="filter-map" class="select select-bordered select-sm">
                <option value="">全て</option>
              </select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">結果</span></label>
              <select id="filter-result" class="select select-bordered select-sm">
                <option value="">全て</option>
                <option value="S">S勝利</option>
                <option value="A">A勝利</option>
                <option value="B">B勝利</option>
                <option value="C">C敗北</option>
                <option value="D">D敗北</option>
              </select>
            </div>
            <button id="btn-load" class="btn btn-primary btn-sm">読込</button>
          </div>
        </div>
      </div>

      <!-- Battle List -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-zebra table-sm">
              <thead>
                <tr>
                  <th>日時</th>
                  <th>マップ</th>
                  <th>セル</th>
                  <th>陣形</th>
                  <th>制空</th>
                  <th>結果</th>
                  <th>ドロップ</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="battle-table-body">
                <tr>
                  <td colspan="8" class="text-center py-12 text-base-content/40">
                    <span class="loading loading-spinner loading-md"></span>
                    <p class="mt-2">「読込」ボタンを押してデータを取得</p>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <!-- Pagination -->
          <div class="flex justify-center py-4 gap-2" id="pagination"></div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  const WIN_RANK_BADGES: Record<string, string> = {
    S: "badge-success",
    A: "badge-info",
    B: "badge-warning",
    C: "badge-error",
    D: "badge-error",
    E: "badge-error",
  };

  const FORMATION_NAMES: Record<number, string> = {
    1: "単縦陣",
    2: "複縦陣",
    3: "輪形陣",
    4: "梯形陣",
    5: "単横陣",
    6: "警戒陣",
    11: "第一警戒航行序列",
    12: "第二警戒航行序列",
    13: "第三警戒航行序列",
    14: "第四警戒航行序列",
  };

  const AIR_SUPERIORITY_NAMES: Record<number, string> = {
    0: "航空均衡",
    1: "制空権確保",
    2: "航空優勢",
    3: "航空劣勢",
    4: "制空権喪失",
  };

  interface BattleRecord {
    timestamp: number | null;
    cell_id: number;
    formation: number[] | null;
    battle_result: { win_rank: string; drop_ship_id: number | null } | null;
    opening_air_attack: Array<{ air_superiority: number | null } | null> | null;
    deck_id: number | null;
  }

  let allBattles: BattleRecord[] = [];
  let currentPage = 0;
  const PAGE_SIZE = 50;

  function formatTimestamp(ts: number | null): string {
    if (!ts) return "-";
    const d = new Date(ts);
    return d.toLocaleString("ja-JP", { timeZone: "Asia/Tokyo" });
  }

  function renderBattles() {
    const tbody = document.getElementById("battle-table-body")!;
    const filterResult = (document.getElementById("filter-result") as unknown as HTMLSelectElement).value;

    let filtered = allBattles;
    if (filterResult) {
      filtered = filtered.filter(
        (b) => b.battle_result?.win_rank === filterResult,
      );
    }

    const start = currentPage * PAGE_SIZE;
    const page = filtered.slice(start, start + PAGE_SIZE);

    if (page.length === 0) {
      tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12 text-base-content/40">データがありません</td></tr>`;
      return;
    }

    tbody.innerHTML = page
      .map(
        (b, i) => {
          const rank = b.battle_result?.win_rank ?? "-";
          const badgeClass = WIN_RANK_BADGES[rank] ?? "";
          const formation = b.formation?.[0] ?? 0;
          const airSup =
            b.opening_air_attack?.[0]?.air_superiority ?? null;

          return `<tr class="hover cursor-pointer" data-idx="${start + i}">
          <td class="whitespace-nowrap">${formatTimestamp(b.timestamp)}</td>
          <td>-</td>
          <td>${b.cell_id}</td>
          <td>${FORMATION_NAMES[formation] ?? "-"}</td>
          <td>${airSup !== null ? AIR_SUPERIORITY_NAMES[airSup] ?? airSup : "-"}</td>
          <td><span class="badge ${badgeClass} badge-sm">${rank}</span></td>
          <td>${b.battle_result?.drop_ship_id ? `#${b.battle_result.drop_ship_id}` : "-"}</td>
          <td><a href="/battles/${start + i}" class="btn btn-ghost btn-xs">詳細</a></td>
        </tr>`;
        },
      )
      .join("");

    // Pagination
    const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
    const pagination = document.getElementById("pagination")!;
    if (totalPages <= 1) {
      pagination.innerHTML = "";
      return;
    }
    pagination.innerHTML = Array.from({ length: Math.min(totalPages, 10) }, (_, i) => {
      const active = i === currentPage ? "btn-active" : "";
      return `<button class="btn btn-sm ${active}" data-page="${i}">${i + 1}</button>`;
    }).join("");

    pagination.querySelectorAll("button").forEach((btn) => {
      btn.addEventListener("click", () => {
        currentPage = parseInt(btn.dataset.page ?? "0", 10);
        renderBattles();
      });
    });

    // Row click → detail page
    tbody.querySelectorAll("tr[data-idx]").forEach((row) => {
      row.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("a")) return;
        const idx = parseInt((row as HTMLElement).dataset.idx ?? "0", 10);
        const battle = allBattles[idx];
        if (battle) {
          sessionStorage.setItem("battleDetail", JSON.stringify(battle));
          window.location.href = `/battles/${idx}`;
        }
      });
    });
  }

  // Load button handler
  document.getElementById("btn-load")?.addEventListener("click", async () => {
    const tbody = document.getElementById("battle-table-body")!;
    tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12"><span class="loading loading-spinner loading-md"></span><p class="mt-2">読込中...</p></td></tr>`;

    try {
      // This calls the data_loader API which requires API key.
      // For the web UI, we use the JWT-based auth endpoint instead.
      const periodEl = document.getElementById("filter-period") as unknown as HTMLSelectElement;
      const periodTag = periodEl?.value ?? "latest";

      // Fetch battles via internal API (battle table from D1/R2)
      const res = await fetch(`/api/data-loader/data/battle?period_tag=${periodTag}`, {
        headers: {
          "Content-Type": "application/json",
        },
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({})) as Record<string, unknown>;
        tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12 text-error">${(err?.message as string) || "データの取得に失敗しました。API KeyとClient IDが必要です。"}</td></tr>`;
        return;
      }

      const data = await res.json() as { files?: Array<{ download_url: string }>; count?: number };

      if (data.files && data.files.length > 0) {
        // Download the first file to get actual battle data
        const firstFile = data.files[0];
        const downloadRes = await fetch(`/api${firstFile.download_url}`);
        if (downloadRes.ok) {
          const avroData = await downloadRes.arrayBuffer();
          // TODO: Avro decoding with avro-wasm
          // For now, show file metadata
          allBattles = [];
          tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12 text-base-content/60">
            ${data.count ?? 0}件のデータファイルが見つかりました。<br>
            Avroデコード機能は開発中です。
          </td></tr>`;
        }
      } else {
        tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12 text-base-content/40">データがありません</td></tr>`;
      }
    } catch (err) {
      console.error("Failed to load battles:", err);
      const tbody = document.getElementById("battle-table-body")!;
      tbody.innerHTML = `<tr><td colspan="8" class="text-center py-12 text-error">読込エラー: ${err}</td></tr>`;
    }
  });
</script>
