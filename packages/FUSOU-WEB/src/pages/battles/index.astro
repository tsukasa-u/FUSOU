---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/common/astro/layout/Navigation.astro";
import BattlesDashboard from "@/components/features/battles/solid/BattlesDashboard";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Battles"
  tutorial={{
    id: "battles-index",
    title: "戦闘一覧ページの使い方",
    summary: "条件で絞り込みながら対象戦闘を探せます。",
    controls: [
      {
        sourceSelector: "#battles-filter-period",
        description: "集計対象期間（最新 / 全期間）を切り替えます。",
        tone: "outline",
      },
      {
        sourceSelector: "#battles-filter-map",
        description: "海域で絞り込み、対象マップの戦闘だけを表示します。",
        tone: "outline",
      },
      {
        sourceSelector: "#battles-filter-result",
        description: "勝敗ランクで絞り込み、S勝利や敗北戦闘を比較できます。",
        tone: "outline",
      },
      {
        sourceSelector: "#battles-load-btn",
        description: "最新の条件で戦闘一覧を再取得します。",
        tone: "primary",
      },
      {
        sourceSelector: "#battles-detail-link",
        description: "選択した行の戦闘詳細ページへ移動します。",
        tone: "ghost",
      },
      {
        sourceSelector: "#tutorial-open-btn",
        description: "この説明モーダルを再表示します。",
        tone: "primary",
      },
    ],
    steps: [
      "フィルタで期間・海域・勝敗を絞り込みます。",
      "行をクリックして戦闘詳細へ遷移します。",
      "タブからマップ進行・統計に切り替えて分析します。",
    ],
  }}
>
  <Navigation filled={true} />
  <BattlesDashboard client:only="solid-js" />
</PageLayout>
