---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import BattleStatsPanel from "@/components/solid/BattleStatsPanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;

const periodTag = Astro.url.searchParams.get("period_tag")?.trim();
const tableVersion = Astro.url.searchParams.get("table_version")?.trim();
const sharedParams = new URLSearchParams();
if (periodTag) {
  sharedParams.set("period_tag", periodTag);
}
if (tableVersion) {
  sharedParams.set("table_version", tableVersion);
}
const sharedQuery = sharedParams.toString();
const battlesHref = sharedQuery ? `/battles?${sharedQuery}` : "/battles";
---

<PageLayout
  title="FUSOU - Statistics"
  tutorial={{
    id: "battles-stats",
    title: "統計ダッシュボードの使い方",
    summary: "戦闘データを集計して傾向を把握できます。",
    controls: [
      {
        sourceSelector: "#battle-stats-filter-period",
        description: "集計期間（最新 / 全期間）を切り替えます。",
        tone: "outline",
      },
      {
        sourceSelector: "#battle-stats-aggregate-btn",
        description: "現在条件で統計を再計算し、グラフと分布を更新します。",
        tone: "primary",
      },
      {
        sourceSelector: "#stats-back-link",
        description:
          "戦闘一覧ページに戻ります。個別戦闘の詳細を確認したい場合に使います。",
        tone: "ghost",
      },
      {
        sourceSelector: "#tutorial-open-btn",
        description:
          "この説明モーダルを再表示します。操作方法を確認したいときに利用してください。",
        tone: "primary",
      },
    ],
    steps: [
      "グラフと集計値を見て海域・敵編成の傾向を把握します。勝率・ダメージ分布なども確認できます。",
      "期間・海域・戦闘種別にフィルタを変えると綞り込み後の傾向も読み取れます。",
      "分析結果をもとに戦闘一覧へ戻り、個別戦闘と突き合わせて検証します。",
      "統計データをもとに編成・装備の改善方針を検討します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="統計ダッシュボード"
      subtitle="戦闘データの統計情報を可視化"
    >
      <Fragment slot="actions">
        <a id="stats-back-link" href={battlesHref} class="fusou-btn-ghost"
          >← 戦闘一覧</a
        >
      </Fragment>
    </PageHeader>

    <BattleStatsPanel client:only="solid-js" />
  </PageShell>
</PageLayout>
