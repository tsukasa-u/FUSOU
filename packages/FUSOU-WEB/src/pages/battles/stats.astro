---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import BattleStatsPanel from "@/components/solid/BattleStatsPanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Statistics"
  tutorial={{
    id: "battles-stats",
    title: "統計ダッシュボードの使い方",
    summary: "戦闘データを集計して傾向を把握できます。",
    steps: [
      "グラフと集計値を見て海域・敵編成の傾向を確認します。",
      "必要に応じて戦闘一覧へ戻り、個別戦闘と突き合わせます。",
      "分析結果をもとに編成・装備の改善方針を検討します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="統計ダッシュボード"
      subtitle="戦闘データの統計情報を可視化"
    >
      <Fragment slot="actions">
        <a href="/battles" class="fusou-btn-ghost">← 戦闘一覧</a>
      </Fragment>
    </PageHeader>

    <BattleStatsPanel client:only="solid-js" />
  </PageShell>
</PageLayout>
