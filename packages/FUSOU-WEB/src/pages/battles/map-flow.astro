---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import BattleMapFlowPanel from "@/components/solid/map-flow/BattleMapFlowPanel";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Map Flow"
  tutorial={{
    id: "battles-map-flow",
    title: "マップ進行ページの使い方",
    summary: "進軍ルートと交戦内容を同時に追跡できます。",
    steps: [
      "ルート上のセルを選択して交戦した戦闘を確認します。",
      "表示設定で注目したい情報（敵編成や分岐）を切り替えます。",
      "詳細分析が必要な戦闘は戦闘詳細ページへ移動します。",
    ],
  }}
>
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <div
        class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4"
      >
        <div>
          <h1 class="text-3xl font-bold">マップ進行</h1>
          <p class="text-base-content/60 mt-1">
            進軍順路と交戦した敵を同時に確認
          </p>
        </div>
        <a href="/battles" class="btn btn-ghost btn-sm">← 戦闘一覧</a>
      </div>

      <BattleMapFlowPanel client:only="solid-js" />
    </div>
  </div>
</PageLayout>
