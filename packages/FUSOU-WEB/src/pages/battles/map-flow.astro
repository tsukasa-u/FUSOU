---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import BattleMapFlowPanel from "@/components/solid/map-flow/BattleMapFlowPanel";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Map Flow"
  tutorial={{
    id: "battles-map-flow",
    title: "マップ進行ページの使い方",
    summary: "進軍ルートと交戦内容を同時に追跡できます。",
    steps: [
      "ルート上のセルを選択して交戦した戦闘を確認します。",
      "表示設定で注目したい情報（敵編成や分岐）を切り替えます。",
      "詳細分析が必要な戦闘は戦闘詳細ページへ移動します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader title="マップ進行" subtitle="進軍順路と交戦した敵を同時に確認">
      <Fragment slot="actions">
        <a href="/battles" class="fusou-btn-ghost">← 戦闘一覧</a>
      </Fragment>
    </PageHeader>

    <BattleMapFlowPanel client:only="solid-js" />
  </PageShell>
</PageLayout>
