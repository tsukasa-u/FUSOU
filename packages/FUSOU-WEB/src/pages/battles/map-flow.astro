---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import { CellFlowChart } from "@/components/react/CellFlowChart";

export const prerender = false;
---

<PageLayout title="FUSOU - Map Flow">
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4">
        <div>
          <h1 class="text-3xl font-bold">マップ進行</h1>
          <p class="text-base-content/60 mt-1">セル遷移の頻度と進行パターンを分析</p>
        </div>
        <a href="/battles" class="btn btn-ghost btn-sm">← 戦闘一覧</a>
      </div>

      <!-- Filters -->
      <div class="card bg-base-100 shadow-sm mb-6">
        <div class="card-body p-4">
          <div class="flex flex-wrap gap-4 items-end">
            <div class="form-control">
              <label class="label"><span class="label-text">マップ</span></label>
              <select id="filter-map" class="select select-bordered select-sm">
                <option value="">全て</option>
              </select>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">期間</span></label>
              <select id="filter-period" class="select select-bordered select-sm">
                <option value="latest">最新</option>
                <option value="all">全期間</option>
              </select>
            </div>
            <button id="btn-load" class="btn btn-primary btn-sm">読込</button>
          </div>
        </div>
      </div>

      <!-- Flow Diagram (SVG) -->
      <div class="card bg-base-100 shadow-sm mb-6">
        <div class="card-body">
          <h3 class="card-title text-lg">セル進行フロー</h3>
          <div class="overflow-x-auto" id="flow-container">
            <div class="flex items-center justify-center h-64 text-base-content/40">
              データを読み込むとフロー図が表示されます
            </div>
          </div>
        </div>
      </div>

      <!-- Cell Transition Frequency Chart -->
      <div class="card bg-base-100 shadow-sm mb-6">
        <div class="card-body">
          <h3 class="card-title text-lg">セル遷移頻度</h3>
          <div id="chart-mount">
            <CellFlowChart client:only="react" transitions={[]} />
          </div>
        </div>
      </div>

      <!-- Per-Cell Stats Table -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-zebra table-sm">
              <thead>
                <tr>
                  <th>セル</th>
                  <th>通過回数</th>
                  <th>遷移先</th>
                  <th>戦闘率</th>
                  <th>ボス</th>
                </tr>
              </thead>
              <tbody id="cell-stats-body">
                <tr>
                  <td colspan="5" class="text-center py-8 text-base-content/40">
                    データ読込後に表示されます
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  interface CellRecord {
    maparea_id: number;
    mapinfo_no: number;
    cell_id: number;
    next_cell?: number | null;
    event_id?: number;
    event_kind?: number;
    battle_uuid?: string;
    timestamp?: number;
  }

  interface Transition {
    from: number;
    to: number;
    count: number;
  }

  interface CellStat {
    cell: number;
    passCount: number;
    nextCells: Map<number, number>;
    battleCount: number;
    isBoss: boolean;
  }

  function buildFlowSVG(stats: CellStat[], transitions: Transition[]) {
    const container = document.getElementById("flow-container")!;

    if (stats.length === 0) {
      container.innerHTML = `<div class="flex items-center justify-center h-64 text-base-content/40">マップデータがありません</div>`;
      return;
    }

    // Simple directed graph layout
    const cells = stats.sort((a, b) => a.cell - b.cell);
    const maxCount = Math.max(...transitions.map((t) => t.count), 1);

    const nodeSpacing = 100;
    const cols = Math.min(cells.length, 6);
    const rows = Math.ceil(cells.length / cols);
    const width = cols * nodeSpacing + 80;
    const height = rows * nodeSpacing + 80;

    const positions = new Map<number, { x: number; y: number }>();
    cells.forEach((c, i) => {
      const col = i % cols;
      const row = Math.floor(i / cols);
      positions.set(c.cell, { x: col * nodeSpacing + 60, y: row * nodeSpacing + 60 });
    });

    let svg = `<svg viewBox="0 0 ${width} ${height}" class="w-full" style="max-height: 500px">`;
    svg += `<defs><marker id="arrow" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto"><polygon points="0 0, 10 3.5, 0 7" fill="#888"/></marker></defs>`;

    // Edges
    for (const t of transitions) {
      const from = positions.get(t.from);
      const to = positions.get(t.to);
      if (!from || !to) continue;
      const thickness = Math.max(1, (t.count / maxCount) * 6);
      const opacity = Math.max(0.2, t.count / maxCount);
      svg += `<line x1="${from.x}" y1="${from.y}" x2="${to.x}" y2="${to.y}" stroke="#6A7FDB" stroke-width="${thickness}" opacity="${opacity}" marker-end="url(#arrow)"/>`;
    }

    // Nodes
    for (const c of cells) {
      const pos = positions.get(c.cell)!;
      const r = c.isBoss ? 22 : 18;
      const fill = c.isBoss ? "#F87171" : "#6A7FDB";
      svg += `<circle cx="${pos.x}" cy="${pos.y}" r="${r}" fill="${fill}" stroke="white" stroke-width="2"/>`;
      svg += `<text x="${pos.x}" y="${pos.y + 4}" text-anchor="middle" fill="white" font-size="12" font-weight="bold">${c.cell}</text>`;
    }

    svg += `</svg>`;
    container.innerHTML = svg;
  }

  document.getElementById("btn-load")?.addEventListener("click", async () => {
    const container = document.getElementById("flow-container")!;
    container.innerHTML = `<div class="flex items-center justify-center h-64"><span class="loading loading-spinner loading-md"></span></div>`;

    try {
      const periodEl = document.getElementById("filter-period") as unknown as HTMLSelectElement;
      const periodTag = periodEl?.value ?? "latest";

      const res = await fetch(`/api/data-loader/data/cells?period_tag=${periodTag}`, {
        headers: { "Content-Type": "application/json" },
      });

      if (!res.ok) {
        container.innerHTML = `<div class="text-center text-error py-8">データの取得に失敗しました</div>`;
        return;
      }

      const data = await res.json() as { records?: CellRecord[] };

      if (!data.records || data.records.length === 0) {
        container.innerHTML = `<div class="text-center text-base-content/40 py-8">セルデータがありません。Avroデコード機能は開発中です。</div>`;

        const statsBody = document.getElementById("cell-stats-body")!;
        statsBody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-base-content/40">データなし</td></tr>`;
        return;
      }

      // Build transitions
      const transitionMap = new Map<string, Transition>();
      const cellStats = new Map<number, CellStat>();

      for (const rec of data.records) {
        let stat = cellStats.get(rec.cell_id);
        if (!stat) {
          stat = { cell: rec.cell_id, passCount: 0, nextCells: new Map(), battleCount: 0, isBoss: false };
          cellStats.set(rec.cell_id, stat);
        }
        stat.passCount++;
        if (rec.event_id === 5) stat.isBoss = true;
        if (rec.event_id !== undefined && [4, 5].includes(rec.event_id)) stat.battleCount++;

        if (rec.next_cell != null) {
          const key = `${rec.cell_id}->${rec.next_cell}`;
          const existing = transitionMap.get(key);
          if (existing) {
            existing.count++;
          } else {
            transitionMap.set(key, { from: rec.cell_id, to: rec.next_cell, count: 1 });
          }
          stat.nextCells.set(rec.next_cell, (stat.nextCells.get(rec.next_cell) ?? 0) + 1);
        }
      }

      const transitions = [...transitionMap.values()];
      const stats = [...cellStats.values()];

      // Render flow diagram
      buildFlowSVG(stats, transitions);

      // Render stats table
      const statsBody = document.getElementById("cell-stats-body")!;
      statsBody.innerHTML = stats
        .sort((a, b) => b.passCount - a.passCount)
        .map((s) => {
          const nexts = [...s.nextCells.entries()]
            .sort((a, b) => b[1] - a[1])
            .map(([cell, count]) => `${cell}(${count})`)
            .join(", ");
          const battleRate = s.passCount > 0 ? ((s.battleCount / s.passCount) * 100).toFixed(0) : "0";
          return `<tr>
            <td>${s.cell}</td>
            <td>${s.passCount}</td>
            <td class="text-xs">${nexts || "-"}</td>
            <td>${battleRate}%</td>
            <td>${s.isBoss ? '<span class="badge badge-error badge-sm">BOSS</span>' : "-"}</td>
          </tr>`;
        })
        .join("");

    } catch (err) {
      console.error("Failed to load cell data:", err);
      container.innerHTML = `<div class="text-center text-error py-8">読込エラー</div>`;
    }
  });
</script>
