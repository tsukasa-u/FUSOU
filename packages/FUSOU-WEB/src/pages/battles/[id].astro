---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";

export const prerender = false;

const { id } = Astro.params;
---

<PageLayout title="FUSOU - Battle Detail">
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <!-- Back link -->
      <div class="mb-4">
        <a href="/battles" class="btn btn-ghost btn-sm gap-1">
          ← 戦闘一覧に戻る
        </a>
      </div>

      <!-- Battle Header -->
      <div class="card bg-base-100 shadow-sm mb-6" id="battle-header">
        <div class="card-body">
          <h2 class="card-title">戦闘詳細</h2>
          <div class="flex flex-wrap gap-6 text-sm" id="battle-meta">
            <span class="text-base-content/60">データ読込中...</span>
          </div>
        </div>
      </div>

      <!-- Formation & Air State -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-sm text-base-content/60">陣形</h3>
            <div class="flex gap-4" id="formation-display">
              <div>
                <span class="text-xs text-base-content/40">味方</span>
                <p class="text-lg font-bold" id="f-formation">-</p>
              </div>
              <div>
                <span class="text-xs text-base-content/40">敵</span>
                <p class="text-lg font-bold" id="e-formation">-</p>
              </div>
            </div>
          </div>
        </div>
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-sm text-base-content/60">制空状態</h3>
            <p class="text-lg font-bold" id="air-state">-</p>
          </div>
        </div>
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-sm text-base-content/60">戦闘結果</h3>
            <p class="text-2xl font-bold" id="battle-rank">-</p>
            <p class="text-sm" id="drop-info"></p>
          </div>
        </div>
      </div>

      <!-- HP Gauges -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
        <!-- Friendly Fleet HP -->
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-sm text-base-content/60 mb-2">味方艦隊</h3>
            <div class="space-y-2" id="f-fleet-hp"></div>
          </div>
        </div>
        <!-- Enemy Fleet HP -->
        <div class="card bg-base-100 shadow-sm">
          <div class="card-body p-4">
            <h3 class="font-bold text-sm text-base-content/60 mb-2">敵艦隊</h3>
            <div class="space-y-2" id="e-fleet-hp"></div>
          </div>
        </div>
      </div>

      <!-- Battle Phases Timeline -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body">
          <h3 class="card-title text-lg">戦闘フェーズ</h3>
          <div class="space-y-4" id="battle-phases">
            <div class="text-center text-base-content/40 py-8">
              戦闘データが読み込まれると、各フェーズのダメージが表示されます
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script define:vars={{ battleId: id }}>
  // Battle phase type names
  const PHASE_NAMES = {
    AirBaseAssult: "基地航空隊突撃",
    CarrierBaseAssault: "空母機動部隊",
    AirBaseAirAttack: "基地航空隊",
    OpeningAirAttack: "開幕航空戦",
    SupportAttack: "支援攻撃",
    OpeningTaisen: "開幕対潜",
    OpeningRaigeki: "開幕雷撃",
    Hougeki: "砲撃戦",
    ClosingRaigeki: "閉幕雷撃",
    FriendlyForceAttack: "友軍艦隊",
    MidnightHougeki: "夜戦",
  };

  const FORMATION_NAMES = {
    1: "単縦陣",
    2: "複縦陣",
    3: "輪形陣",
    4: "梯形陣",
    5: "単横陣",
    6: "警戒陣",
    11: "第一警戒航行序列",
    12: "第二警戒航行序列",
    13: "第三警戒航行序列",
    14: "第四警戒航行序列",
  };

  const AIR_STATE = {
    0: { label: "航空均衡", cls: "text-warning" },
    1: { label: "制空権確保", cls: "text-success" },
    2: { label: "航空優勢", cls: "text-info" },
    3: { label: "航空劣勢", cls: "text-error" },
    4: { label: "制空権喪失", cls: "text-error" },
  };

  const RANK_COLORS = {
    S: "text-success",
    A: "text-info",
    B: "text-warning",
    C: "text-error",
    D: "text-error",
    E: "text-error",
  };

  function normalizeEpochMs(value) {
    if (value == null) return null;
    const n = Number(value);
    if (!Number.isFinite(n)) return null;
    return n < 1_000_000_000_000 ? n * 1000 : n;
  }

  function resolveBattleResult(raw, battleResultByUuid) {
    if (!raw) return null;
    if (typeof raw === "string") {
      return battleResultByUuid.get(raw) ?? null;
    }
    if (typeof raw === "object" && raw.win_rank) {
      return {
        win_rank: raw.win_rank,
        drop_ship_id: raw.drop_ship_id ?? null,
      };
    }
    return null;
  }

  async function fetchBattleResultByUuid(uuid) {
    if (!uuid) return null;
    try {
      const filterJson = encodeURIComponent(JSON.stringify({ uuid }));
      const response = await fetch(
        `/api/battle-data/global/records?table=battle_result&period_tag=all&limit_blocks=120&limit_records=50&filter_json=${filterJson}`,
      );
      if (!response.ok) return null;
      const payload = await response.json();
      const item = (payload.records || []).find((r) => r?.uuid === uuid && r?.win_rank);
      if (!item?.win_rank) return null;
      return {
        win_rank: item.win_rank,
        drop_ship_id: item.drop_ship_id ?? null,
      };
    } catch {
      return null;
    }
  }

  function renderHPBar(current, max, label = "") {
    const pct = max > 0 ? Math.max(0, (current / max) * 100) : 0;
    let color = "bg-success";
    if (pct <= 25) color = "bg-error";
    else if (pct <= 50) color = "bg-warning";
    else if (pct <= 75) color = "bg-info";

    return `<div class="flex items-center gap-2">
      <span class="text-xs w-20 truncate">${label}</span>
      <div class="flex-1 h-4 bg-base-300 rounded-full overflow-hidden relative">
        <div class="h-full ${color} rounded-full transition-all" style="width: ${pct}%"></div>
        <span class="absolute inset-0 flex items-center justify-center text-xs font-mono">${current}/${max}</span>
      </div>
    </div>`;
  }

  function renderPhase(phaseType, phaseData) {
    // Extract phase name from battle_order entry
    let phaseName = "不明";
    let phaseKey = "";
    if (typeof phaseType === "object") {
      phaseKey = Object.keys(phaseType)[0];
      phaseName = PHASE_NAMES[phaseKey] ?? phaseKey;
      const subIdx = phaseType[phaseKey];
      if (subIdx !== null && subIdx !== undefined) {
        phaseName += ` (${subIdx + 1})`;
      }
    }

    let damageRows = "";

    if (phaseKey === "Hougeki" || phaseKey === "OpeningTaisen" || phaseKey === "MidnightHougeki") {
      // Shelling-type phases
      const data = phaseData;
      if (data?.at_list) {
        for (let i = 0; i < data.at_list.length; i++) {
          const attacker = data.at_list[i];
          const defenders = data.df_list?.[i] ?? [];
          const damages = data.damage?.[i] ?? [];
          const isEnemy = data.at_eflag?.[i] ?? 0;
          const side = isEnemy ? "🔴" : "🔵";
          const totalDmg = damages.reduce((s, d) => s + d, 0);
          damageRows += `<div class="flex items-center gap-2 text-xs py-1 border-b border-base-200">
            <span>${side}</span>
            <span class="w-12">艦${attacker}</span>
            <span class="text-base-content/40">→</span>
            <span class="w-12">艦${defenders.join(",")}</span>
            <span class="font-mono ${totalDmg > 0 ? "text-error" : "text-base-content/40"}">${totalDmg}dmg</span>
          </div>`;
        }
      }
    } else if (phaseKey === "OpeningRaigeki" || phaseKey === "ClosingRaigeki") {
      // Torpedo-type phases
      const data = phaseData;
      if (data?.fdam) {
        const fTotal = data.fdam.reduce((s, d) => s + d, 0);
        const eTotal = data.edam.reduce((s, d) => s + d, 0);
        damageRows = `<div class="flex gap-4 text-sm">
          <span>味方被ダメ: <span class="font-mono text-error">${fTotal}</span></span>
          <span>敵被ダメ: <span class="font-mono text-error">${eTotal}</span></span>
        </div>`;
      }
    } else if (phaseKey === "OpeningAirAttack" || phaseKey === "AirBaseAirAttack") {
      // Air attack phases
      const data = phaseData;
      if (data?.f_damage || data?.e_damage) {
        const fDmg = data.f_damage?.damages?.reduce((s, d) => s + d, 0) ?? 0;
        const eDmg = data.e_damage?.damages?.reduce((s, d) => s + d, 0) ?? 0;
        const fLoss = data.f_damage?.loss_plane1 ?? 0;
        const eLoss = data.e_damage?.loss_plane1 ?? 0;
        damageRows = `<div class="flex gap-4 text-sm">
          <span>味方被ダメ: <span class="font-mono text-error">${fDmg}</span> (撃墜: ${fLoss}機)</span>
          <span>敵被ダメ: <span class="font-mono text-error">${eDmg}</span> (撃墜: ${eLoss}機)</span>
        </div>`;
      }
    } else if (phaseKey === "SupportAttack") {
      const data = phaseData;
      if (data?.support_hourai) {
        const totalDmg = data.support_hourai.damage?.reduce((s, d) => s + d, 0) ?? 0;
        damageRows = `<div class="text-sm">敵被ダメ合計: <span class="font-mono text-error">${totalDmg}</span></div>`;
      }
      if (data?.support_airatack) {
        const eDmg = data.support_airatack.e_damage?.damages?.reduce((s, d) => s + d, 0) ?? 0;
        damageRows += `<div class="text-sm">航空支援敵被ダメ: <span class="font-mono text-error">${eDmg}</span></div>`;
      }
    }

    if (!damageRows) {
      damageRows = `<div class="text-xs text-base-content/40">データなし</div>`;
    }

    return `<div class="collapse collapse-arrow bg-base-200 rounded-lg">
      <input type="checkbox" checked />
      <div class="collapse-title font-bold">${phaseName}</div>
      <div class="collapse-content">${damageRows}</div>
    </div>`;
  }

  function renderBattle(battle, mapLabel) {
    // Meta
    const metaEl = document.getElementById("battle-meta");
    const tsValue = normalizeEpochMs(battle.timestamp) ?? normalizeEpochMs(battle.midnight_timestamp);
    const ts = tsValue
      ? new Date(tsValue).toLocaleString("ja-JP", { timeZone: "Asia/Tokyo" })
      : "-";
    const mapText = mapLabel || (battle.maparea_id && battle.mapinfo_no ? `${battle.maparea_id}-${battle.mapinfo_no}` : "-");
    metaEl.innerHTML = `
      <span>日時: <strong>${ts}</strong></span>
      <span>海域: <strong>${mapText}</strong></span>
      <span>セル: <strong>${battle.cell_id}</strong></span>
      <span>デッキ: <strong>${battle.deck_id ?? "-"}</strong></span>
    `;

    // Formation
    const fForm = battle.f_formation ?? battle.formation?.[0] ?? 0;
    const eForm = battle.e_formation ?? battle.formation?.[1] ?? 0;
    document.getElementById("f-formation").textContent = FORMATION_NAMES[fForm] ?? "-";
    document.getElementById("e-formation").textContent = FORMATION_NAMES[eForm] ?? "-";

    // Air state
    const airSup = battle.opening_air_attack?.[0]?.air_superiority;
    const airInfo = AIR_STATE[airSup] ?? { label: "-", cls: "" };
    const airEl = document.getElementById("air-state");
    airEl.textContent = airInfo.label;
    airEl.className = `text-lg font-bold ${airInfo.cls}`;

    // Battle result
    const rank = battle.battle_result?.win_rank ?? "-";
    const rankEl = document.getElementById("battle-rank");
    rankEl.textContent = rank;
    rankEl.className = `text-2xl font-bold ${RANK_COLORS[rank] ?? ""}`;

    const dropEl = document.getElementById("drop-info");
    if (battle.battle_result?.drop_ship_id) {
      dropEl.textContent = `ドロップ: 艦#${battle.battle_result.drop_ship_id}`;
    }

    // HP Bars
    const fHPs = battle.f_nowhps ?? [];
    const eHPs = battle.e_nowhps ?? [];
    const eMaxHPs = battle.e_hp_max ?? [];

    document.getElementById("f-fleet-hp").innerHTML =
      fHPs.map((hp, i) => renderHPBar(hp, hp, `味方${i + 1}`)).join("") || "データなし";

    document.getElementById("e-fleet-hp").innerHTML =
      eHPs.map((hp, i) => renderHPBar(hp, eMaxHPs[i] ?? hp, `敵${i + 1}`)).join("") || "データなし";

    // Battle phases
    const phasesEl = document.getElementById("battle-phases");
    if (battle.battle_order && battle.battle_order.length > 0) {
      const phaseHtmls = battle.battle_order.map((phaseType) => {
        const key = Object.keys(phaseType)[0];
        const idx = phaseType[key];

        // Map phase to battle data
        let phaseData = null;
        switch (key) {
          case "AirBaseAssult":
            phaseData = battle.air_base_assault;
            break;
          case "CarrierBaseAssault":
            phaseData = battle.carrier_base_assault;
            break;
          case "AirBaseAirAttack":
            phaseData = battle.air_base_air_attacks?.attacks?.[idx ?? 0];
            break;
          case "OpeningAirAttack":
            phaseData = battle.opening_air_attack?.[idx ?? 0];
            break;
          case "SupportAttack":
            phaseData = battle.support_attack;
            break;
          case "OpeningTaisen":
            phaseData = battle.opening_taisen;
            break;
          case "OpeningRaigeki":
            phaseData = battle.opening_raigeki;
            break;
          case "Hougeki":
            phaseData = battle.hougeki?.[idx ?? 0];
            break;
          case "ClosingRaigeki":
            phaseData = battle.closing_raigeki;
            break;
          case "FriendlyForceAttack":
            phaseData = battle.friendly_force_attack;
            break;
          case "MidnightHougeki":
            phaseData = battle.midnight_hougeki;
            break;
        }
        return renderPhase(phaseType, phaseData);
      });
      phasesEl.innerHTML = phaseHtmls.join("");
    } else {
      phasesEl.innerHTML = `<div class="text-center text-base-content/40 py-8">戦闘フェーズ情報がありません</div>`;
    }
  }

  async function loadBattleById() {
    const battleData = sessionStorage.getItem("battleDetail");
    if (battleData) {
      try {
        const parsed = JSON.parse(battleData);
        if (parsed) {
          const preloaded = {
            ...parsed,
            timestamp:
              normalizeEpochMs(parsed.timestamp) ?? normalizeEpochMs(parsed.midnight_timestamp) ?? null,
          };
          renderBattle(preloaded);
        }
      } catch (e) {
        console.error("Failed to parse session battle data:", e);
      }
    }

    try {
      const [battleRes, cellsRes, battleResultRes] = await Promise.all([
        fetch(
          `/api/battle-data/global/records?table=battle&period_tag=all&limit_blocks=40&limit_records=20000`,
        ),
        fetch(
          `/api/battle-data/global/records?table=cells&period_tag=all&limit_blocks=40&limit_records=20000`,
        ),
        fetch(
          `/api/battle-data/global/records?table=battle_result&period_tag=all&limit_blocks=40&limit_records=20000`,
        ),
      ]);

      if (!battleRes.ok) {
        const meta = document.getElementById("battle-meta");
        if (meta) {
          meta.innerHTML = `<span class="text-error">戦闘データ取得に失敗しました (${battleRes.status})</span>`;
        }
        return;
      }

      const payload = await battleRes.json();
      const records = payload.records ?? [];
      const cellsPayload = cellsRes.ok ? await cellsRes.json() : { records: [] };
      const battleResultPayload = battleResultRes.ok ? await battleResultRes.json() : { records: [] };

      const mapByBattleUuid = new Map();
      for (const cell of cellsPayload.records || []) {
        if (!cell?.battles) continue;
        const maparea = Number(cell.maparea_id ?? 0);
        const mapinfo = Number(cell.mapinfo_no ?? 0);
        if (maparea > 0 && mapinfo > 0) {
          mapByBattleUuid.set(cell.battles, `${maparea}-${mapinfo}`);
        }
      }

      const battleResultByUuid = new Map();
      for (const item of battleResultPayload.records || []) {
        if (!item?.uuid || !item.win_rank) continue;
        battleResultByUuid.set(item.uuid, {
          win_rank: item.win_rank,
          drop_ship_id: item.drop_ship_id ?? null,
        });
      }
      const idText = String(battleId || "");
      const fallbackIdx = Number.parseInt(idText, 10);

      const candidates = records.filter((r) => String(r.uuid || "") === idText);
      const matched =
        (candidates.length > 0
          ? candidates.sort((a, b) => {
              const ta = normalizeEpochMs(a.timestamp) ?? normalizeEpochMs(a.midnight_timestamp) ?? 0;
              const tb = normalizeEpochMs(b.timestamp) ?? normalizeEpochMs(b.midnight_timestamp) ?? 0;
              return tb - ta;
            })[0]
          : null)
        ?? (Number.isFinite(fallbackIdx) && fallbackIdx >= 0 ? records[fallbackIdx] : null);

      if (matched) {
        let resolvedBattleResult = resolveBattleResult(matched.battle_result, battleResultByUuid);
        if (!resolvedBattleResult && typeof matched.battle_result === "string") {
          resolvedBattleResult = await fetchBattleResultByUuid(matched.battle_result);
        }
        const merged = {
          ...matched,
          timestamp:
            normalizeEpochMs(matched.timestamp) ?? normalizeEpochMs(matched.midnight_timestamp) ?? null,
          battle_result: resolvedBattleResult,
        };
        const mapLabel = matched.uuid ? mapByBattleUuid.get(matched.uuid) : null;
        renderBattle(merged, mapLabel);
      } else {
        const meta = document.getElementById("battle-meta");
        if (meta) {
          meta.innerHTML = `<span class="text-warning">指定された戦闘データが見つかりませんでした</span>`;
        }
      }
    } catch (e) {
      console.error("Failed to load battle detail by id:", e);
      const meta = document.getElementById("battle-meta");
      if (meta) {
        meta.innerHTML = `<span class="text-error">戦闘データ読込中にエラーが発生しました</span>`;
      }
    }
  }

  void loadBattleById();
</script>
