---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/common/astro/layout/Navigation.astro";
import PageShell from "@/components/common/astro/ui/PageShell.astro";
import PageHeader from "@/components/common/astro/ui/PageHeader.astro";
import { createSupabaseServerClient } from "@/lib/supabaseServer";
import { env as cfEnv } from "cloudflare:workers";

export const prerender = false;

const cookies = Astro.cookies;
const runtimeEnv = cfEnv as Record<string, any>;

let safeAccessToken: string | null = null;

const accessTokenCookie = cookies.get("sb-access-token");
const refreshTokenCookie = cookies.get("sb-refresh-token");

if (accessTokenCookie?.value && refreshTokenCookie?.value) {
  try {
    const supabase = createSupabaseServerClient(cookies, runtimeEnv);
    const session = await supabase.auth.setSession({
      refresh_token: refreshTokenCookie.value,
      access_token: accessTokenCookie.value,
    });
    if (session.data.session?.access_token) {
      safeAccessToken = session.data.session.access_token;
    }
  } catch {
    // Session invalid — user is not logged in
  }
}
---

<PageLayout
  title="FUSOU - Fleet List"
  tutorial={{
    id: "simulator-fleets",
    title: "保存済み艦隊ページの使い方",
    summary: "保存済み編成の一覧管理、再読み込み、削除整理を行うページです。",
    controls: [
      {
        label: "新規編成",
        sourceSelector: "#fleets-new-link",
        description: "シミュレータを空編成で開いて新規作成します。",
        tone: "primary",
      },
      {
        label: "シミュレータで開く",
        sourceSelector: ".btn-open-fleet",
        description: "選択した保存編成を即座にシミュレータへ復元します。",
        tone: "outline",
      },
      {
        label: "削除",
        sourceSelector: ".btn-delete",
        description: "不要な保存編成を一覧から削除します。",
        tone: "ghost",
      },
      {
        sourceSelector: "#tutorial-open-btn",
        description: "この説明モーダルを再表示します。",
        tone: "primary",
      },
    ],
    steps: [
      "一覧のタグ名と保存日時を確認し、再利用したい編成を特定します。",
      "シミュレータで開くを押すと、対象編成を読み込んだ状態で編集画面へ移動します。",
      "複数編成を比較したい場合は、順番に開いて共有URLや画像保存を組み合わせて記録します。",
      "不要な編成は削除して、一覧の検索性と管理性を維持します。",
      "新規作業を開始するときは新規編成から空状態で作成を始めてください。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="保存済み艦隊"
      subtitle="R2に保存された艦隊スナップショットの一覧"
    >
      <Fragment slot="actions">
        <a id="fleets-new-link" href="/simulator" class="fusou-btn-primary"
          >新規編成</a
        >
      </Fragment>
    </PageHeader>

    <div class="fusou-card">
      <div class="card-body p-0">
        <div class="overflow-x-auto">
          <table class="table table-zebra table-sm">
            <thead>
              <tr>
                <th>タグ名</th>
                <th>保存日時</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="fleet-list-body">
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </PageShell>

  <!-- Copyright footer -->
  <footer class="fusou-footer-note max-w-[1440px] mx-auto">
    <p
      class="text-xs text-base-content/60 leading-relaxed inline-block text-left text-balance max-w-2xl"
    >
      本サービスで使用する画像・データは著作権法第32条に基づき引用しています。著作権は各権利者に帰属します。権利者からの削除依頼・警告には速やかに対処いたします。お問い合わせは
      <a
        href="/contact"
        class="underline underline-offset-2 hover:text-base-content/60"
        >お問い合わせ・削除申請</a
      >よりご連絡ください。
    </p>
  </footer>
</PageLayout>

<script is:inline define:vars={{ accessToken: safeAccessToken }}>
  window.__fusouAccessToken = accessToken;
</script>

<script>
  import { mountFleetListPanel } from "@/components/features/simulator/solid/FleetListPanel";

  const accessToken = (window as any).__fusouAccessToken ?? null;
  const root = document.getElementById("fleet-list-body");
  if (root) {
    mountFleetListPanel(root, accessToken);
  }
</script>

