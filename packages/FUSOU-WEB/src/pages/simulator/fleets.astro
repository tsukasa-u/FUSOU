---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";

export const prerender = false;
---

<PageLayout title="FUSOU - Fleet List">
  <Navigation filled={true} />
  <div class="pt-16 min-h-screen bg-base-200">
    <div class="max-w-[1440px] mx-auto px-4 py-8">
      <!-- Header -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-6 gap-4">
        <div>
          <h1 class="text-3xl font-bold">保存済み艦隊</h1>
          <p class="text-base-content/60 mt-1">R2に保存された艦隊スナップショットの一覧</p>
        </div>
        <a href="/simulator" class="btn btn-primary btn-sm">新規編成</a>
      </div>

      <!-- Fleet List -->
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-zebra table-sm">
              <thead>
                <tr>
                  <th>タグ名</th>
                  <th>保存日時</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="fleet-list-body">
                <tr>
                  <td colspan="3" class="text-center py-12">
                    <span class="loading loading-spinner loading-md"></span>
                    <p class="mt-2 text-base-content/40">読込中...</p>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<script>
  async function loadFleets() {
    const tbody = document.getElementById("fleet-list-body")!;

    try {
      const res = await fetch("/api/fleet/snapshots/list");
      if (!res.ok) {
        tbody.innerHTML = `<tr><td colspan="3" class="text-center py-12 text-error">読込に失敗しました</td></tr>`;
        return;
      }

      const data = (await res.json()) as { tags: string[] };
      if (!data.tags || data.tags.length === 0) {
        tbody.innerHTML = `<tr><td colspan="3" class="text-center py-12 text-base-content/40">保存された艦隊データがありません</td></tr>`;
        return;
      }

      tbody.innerHTML = data.tags
        .map(
          (tag) => `<tr class="hover">
          <td class="font-mono">${tag}</td>
          <td class="text-base-content/40">-</td>
          <td class="flex gap-1">
            <a href="/simulator?fleet=${encodeURIComponent(tag)}" class="btn btn-primary btn-xs">シミュレータで開く</a>
            <button class="btn btn-ghost btn-xs btn-delete" data-tag="${tag}">削除</button>
          </td>
        </tr>`,
        )
        .join("");
    } catch (err) {
      console.error("Failed to load fleet list:", err);
      tbody.innerHTML = `<tr><td colspan="3" class="text-center py-12 text-error">読込エラー</td></tr>`;
    }
  }

  loadFleets();
</script>
