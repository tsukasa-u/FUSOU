---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Fleet List"
  tutorial={{
    id: "simulator-fleets",
    title: "保存済み艦隊ページの使い方",
    summary: "保存済み編成の一覧管理、再読み込み、削除整理を行うページです。",
    controls: [
      {
        label: "新規編成",
        description: "シミュレータを空編成で開いて新規作成します。",
        tone: "primary",
      },
      {
        label: "シミュレータで開く",
        description: "選択した保存編成を即座にシミュレータへ復元します。",
        tone: "outline",
      },
      {
        label: "削除",
        description: "不要な保存編成を一覧から削除します。",
        tone: "ghost",
      },
      {
        label: "操作説明",
        description: "この説明モーダルを再表示します。",
        tone: "primary",
      },
    ],
    steps: [
      "一覧のタグ名と保存日時を確認し、再利用したい編成を特定します。",
      "シミュレータで開くを押すと、対象編成を読み込んだ状態で編集画面へ移動します。",
      "複数編成を比較したい場合は、順番に開いて共有URLや画像保存を組み合わせて記録します。",
      "不要な編成は削除して、一覧の検索性と管理性を維持します。",
      "新規作業を開始するときは新規編成から空状態で作成を始めてください。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell>
    <PageHeader
      title="保存済み艦隊"
      subtitle="R2に保存された艦隊スナップショットの一覧"
    >
      <Fragment slot="actions">
        <a href="/simulator" class="fusou-btn-primary">新規編成</a>
      </Fragment>
    </PageHeader>

    <div class="fusou-card">
      <div class="card-body p-0">
        <div class="overflow-x-auto">
          <table class="table table-zebra table-sm">
            <thead>
              <tr>
                <th>タグ名</th>
                <th>保存日時</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="fleet-list-body">
              <tr>
                <td colspan="3" class="text-center py-12">
                  <span class="loading loading-spinner loading-md"></span>
                  <p class="mt-2 text-base-content/40">読込中...</p>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </PageShell>

  <!-- Copyright footer -->
  <footer class="fusou-footer-note max-w-[1440px] mx-auto">
    <p
      class="text-xs text-base-content/40 leading-relaxed inline-block text-left text-balance max-w-2xl"
    >
      本サービスで使用する画像・データは著作権法第32条に基づき引用しています。著作権は各権利者に帰属します。権利者からの削除依頼・警告には速やかに対処いたします。お問い合わせは
      <a
        href="/contact"
        class="underline underline-offset-2 hover:text-base-content/60"
        >お問い合わせ・削除申請</a
      >よりご連絡ください。
    </p>
  </footer>
</PageLayout>

<script>
  function renderMessageRow(
    message: string,
    className = "text-base-content/40",
  ) {
    const tr = document.createElement("tr");
    const td = document.createElement("td");
    td.colSpan = 3;
    td.className = `text-center py-12 ${className}`;
    td.textContent = message;
    tr.appendChild(td);
    return tr;
  }

  function renderFleetRow(tag: string) {
    const tr = document.createElement("tr");
    tr.className = "hover";

    const tagTd = document.createElement("td");
    tagTd.className = "font-mono";
    tagTd.textContent = tag;

    const savedAtTd = document.createElement("td");
    savedAtTd.className = "text-base-content/40";
    savedAtTd.textContent = "-";

    const actionsTd = document.createElement("td");
    actionsTd.className = "flex gap-1";

    const openLink = document.createElement("a");
    openLink.href = `/simulator?fleet=${encodeURIComponent(tag)}`;
    openLink.className = "btn btn-primary btn-xs";
    openLink.textContent = "シミュレータで開く";

    const deleteButton = document.createElement("button");
    deleteButton.type = "button";
    deleteButton.className = "btn btn-ghost btn-xs btn-delete";
    deleteButton.dataset.tag = tag;
    deleteButton.textContent = "削除";

    actionsTd.appendChild(openLink);
    actionsTd.appendChild(deleteButton);
    tr.appendChild(tagTd);
    tr.appendChild(savedAtTd);
    tr.appendChild(actionsTd);
    return tr;
  }

  async function loadFleets() {
    const tbody = document.getElementById("fleet-list-body")!;

    try {
      const res = await fetch("/api/fleet/snapshots/list");
      if (!res.ok) {
        tbody.replaceChildren(
          renderMessageRow("読込に失敗しました", "text-error"),
        );
        return;
      }

      const data = (await res.json()) as { tags: string[] };
      if (!data.tags || data.tags.length === 0) {
        tbody.replaceChildren(
          renderMessageRow("保存された艦隊データがありません"),
        );
        return;
      }

      tbody.replaceChildren(...data.tags.map((tag) => renderFleetRow(tag)));
    } catch (err) {
      console.error("Failed to load fleet list:", err);
      tbody.replaceChildren(renderMessageRow("読込エラー", "text-error"));
    }
  }

  loadFleets();
</script>
