---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.astro";
import DataStatusAlert from "@/components/simulator/DataStatusAlert.astro";
import PageShell from "@/components/ui/PageShell.astro";
import PageHeader from "@/components/ui/PageHeader.astro";

export const prerender = false;
---

<PageLayout
  title="FUSOU - Ship & Equipment Details"
  tutorial={{
    id: "simulator-details",
    title: "艦/装備詳細ページの使い方",
    summary:
      "艦娘・装備の詳細値、装備可能条件、シナジー効果まで横断的に確認できます。",
    controls: [
      {
        sourceSelector: "#sim-back-link",
        description: "編成編集画面へ戻り、確認した内容をすぐ反映できます。",
        tone: "outline",
      },
      {
        sourceSelector: "#sim-details-settings-btn",
        description:
          "表示設定で詳細ページとシミュレータ本体の表示密度を調整できます。情報量が多い場合はここで見やすく切り替えます。",
        tone: "outline",
      },
      {
        sourceSelector: "#sim-details-share-btn",
        description:
          "編成画面の共有URLを使うと、詳細ページで確認した条件をそのまま他ユーザーへ共有・再現できます。",
        tone: "primary",
      },
      {
        sourceSelector: "#sim-details-tab-ship",
        description: "艦娘の能力・搭載・速力・射程・成長関連情報を確認します。",
        tone: "ghost",
      },
      {
        sourceSelector: "#sim-details-tab-equip",
        description: "装備の種別・性能・装備可能艦・シナジーを確認します。",
        tone: "ghost",
      },
      {
        sourceSelector: "#sim-details-help-btn",
        description:
          "使い方モーダルを開きます。共有URL発行や表示設定の意味、検索の流れをページ内で確認できます。",
        tone: "outline",
      },
      {
        sourceSelector: "#tutorial-open-btn",
        description: "この説明モーダルを再表示します。",
        tone: "primary",
      },
    ],
    steps: [
      "ページ表示後、マスターデータ読込が完了してから検索・比較を開始してください。",
      "編成の共有や再現が必要な場合は、シミュレータ本体へ戻って共有URLを発行し、この詳細ページと併用して比較内容を伝達してください。",
      "表示設定はシミュレータ本体で変更できます。文字サイズや表示項目を調整してから詳細ページへ戻ると、確認作業が効率化できます。",
      "艦タブでは基本値/最大値、搭載数、速力、射程、艦種など編成判断に必要な情報を確認します。",
      "装備タブでは火力・雷装・対空・命中などの性能値と装備種別を確認できます。",
      "装備詳細のシナジー表示で、単体ボーナス・複数積み効果・艦別適用条件を確認します。",
      "装備可能艦や補強増設条件は一覧を展開して、実運用で積める組み合わせを確認します。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell container="wide" paddingY="6">
    <PageHeader
      title="艦詳細 / 装備詳細"
      subtitle="艦隊シミュレータと並列に、艦と装備の詳細を確認"
      compact={true}
    >
      <Fragment slot="actions">
        <a
          id="sim-open-optimizer-link"
          href="/simulator?tab=optimizer"
          class="fusou-btn-primary">装備最適化を開く</a
        >
        <a id="sim-back-link" href="/simulator" class="fusou-btn-ghost"
          >シミュレータへ戻る</a
        >
      </Fragment>
    </PageHeader>

    <DataStatusAlert mb="mb-4" initialText="マスターデータを読込中..." />

    <div id="simulator-details-root" class="min-h-96"></div>
  </PageShell>

  <!-- Copyright footer -->
  <footer class="fusou-footer-note max-w-[1500px] mx-auto">
    <p
      class="text-xs text-base-content/40 leading-relaxed inline-block text-left text-balance max-w-2xl"
    >
      本サービスで使用する画像・データは著作権法第32条に基づき引用しています。著作権は各権利者に帰属します。権利者からの削除依頼・警告には速やかに対処いたします。お問い合わせは
      <a
        href="/contact"
        class="underline underline-offset-2 hover:text-base-content/60"
        >お問い合わせ・削除申請</a
      >よりご連絡ください。
    </p>
  </footer>
</PageLayout>

<script>
  import { loadMasterData, updateDataStatus } from "./lib/data-loader";
  import { loadFromUrl } from "./lib/io-handlers";
  import { mountSimulatorDetailsCatalog } from "../../components/solid/simulator/simulator-details-catalog";

  async function bootstrap() {
    const root = document.getElementById("simulator-details-root");
    if (!(root instanceof HTMLElement)) return;

    const loadingDiv = document.createElement("div");
    loadingDiv.className =
      "rounded-xl border border-base-300/70 bg-base-100 p-6 flex items-center";
    const spinner = document.createElement("span");
    spinner.className = "loading loading-spinner loading-sm";
    const label = document.createElement("span");
    label.className = "ml-2 text-sm text-base-content/60";
    label.textContent = "詳細データを準備しています...";
    loadingDiv.appendChild(spinner);
    loadingDiv.appendChild(label);
    root.appendChild(loadingDiv);

    updateDataStatus();
    await loadFromUrl();
    await loadMasterData(() => {
      updateDataStatus();
    });

    root.replaceChildren();
    mountSimulatorDetailsCatalog(root);
    updateDataStatus();
  }

  bootstrap();
</script>
