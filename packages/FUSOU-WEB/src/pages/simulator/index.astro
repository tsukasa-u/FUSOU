---
import PageLayout from "@/layouts/Layout.astro";
import Navigation from "@/components/common/astro/layout/Navigation.astro";
import PageShell from "@/components/common/astro/ui/PageShell.astro";
import { createSupabaseServerClient } from "@/lib/supabaseServer";
import { env as cfEnv } from "cloudflare:workers";

export const prerender = false;

// --- SSR: Resolve access token from cookie session ---
const cookies = Astro.cookies;
const runtimeEnv = cfEnv as Record<string, any>;

let safeAccessToken: string | null = null;

const accessTokenCookie = cookies.get("sb-access-token");
const refreshTokenCookie = cookies.get("sb-refresh-token");

if (accessTokenCookie?.value && refreshTokenCookie?.value) {
  try {
    const supabase = createSupabaseServerClient(cookies, runtimeEnv);
    const session = await supabase.auth.setSession({
      refresh_token: refreshTokenCookie.value,
      access_token: accessTokenCookie.value,
    });
    if (session.data.session?.access_token) {
      safeAccessToken = session.data.session.access_token;
    }
  } catch {
    // Session invalid — user is not logged in
  }
}

const tabQuery = Astro.url.searchParams.get("tab") || "fleet";
---

<PageLayout
  title="FUSOU - Fleet Simulator"
  tutorial={{
    id: "simulator-index",
    title: "編成シミュレータの使い方",
    summary:
      "艦隊・装備・基地航空隊を編集し、保存・共有・比較まで一通り行えます。",
    controls: [
      {
        sourceSelector: "#sim-tab-btn-ship",
        description: "艦娘・装備の詳細カタログを別ページで確認します。",
        tone: "outline",
      },
      {
        sourceSelector: "#btn-display-settings",
        description: "表示項目や編成表示の詳細設定を開きます。",
        tone: "outline",
      },
      {
        sourceSelector: "#btn-load-fleet",
        description: "保存済み編成をR2から読み込みます。",
        tone: "outline",
      },
      {
        sourceSelector: "#btn-import",
        description: "API JSONを貼り付けて編成へ反映します。",
        tone: "outline",
      },
      {
        sourceSelector: "#btn-save-image",
        description: "現在の編成表示を画像として保存します。",
        tone: "outline",
      },
      {
        sourceSelector: "#btn-share",
        description: "共有URLを発行して他ユーザーと同じ編成を再現できます。",
        tone: "primary",
      },
      {
        sourceSelector: "#btn-workspace-add-current",
        description: "現在のPlayground編成をワークスペースに登録します。",
        tone: "ghost",
      },
      {
        sourceSelector: "#btn-workspace-add",
        description: "共有URLをワークスペース一覧へ追加します。",
        tone: "ghost",
      },
    ],
    steps: [
      "艦隊カードの艦枠をクリックすると艦選択モーダル、装備枠をクリックすると装備選択モーダルが開きます。",
      "改修値(★)と熟練度は装備バッジ操作で変更でき、ステータス反映をその場で確認できます。",
      "連合艦隊運用時は第1/第2艦隊の役割バッジと警告表示を確認し、編成条件エラーを解消してください。",
      "基地航空隊は各スロットを編集すると行動半径・制空計算に反映されます。",
      "表示設定でUI表示を調整し、閲覧用と編集用の表示密度を切り替えます。",
      "R2読込またはAPIレスポンス貼り付けで既存データを取り込み、手入力を省略できます。",
      "画像保存で記録用画像を作成し、共有ボタンで再現可能なURLを発行します。",
      "ワークスペースの編成追加/URL追加を使うと、複数デッキをページ遷移なしで切り替えて比較できます。",
      "詳細な性能比較は艦/装備詳細ページへ移動して、同時に確認しながら編成を詰めます。",
    ],
  }}
>
  <Navigation filled={true} />
  <PageShell paddingY="6">
    <!-- Mount point for SolidJS Simulator App -->
    <div id="simulator-tab-manager-root"></div>
  </PageShell>

  <!-- Copyright footer -->
  <footer
    class="border-t border-base-300/60 mt-8 py-4 px-4 max-w-[1440px] mx-auto text-center"
  >
    <p
      class="text-xs text-base-content/40 leading-relaxed inline-block text-left [text-wrap:balance] max-w-2xl"
    >
      本サービスで使用する画像・データは著作権法第32条に基づき引用しています。著作権は各権利者に帰属します。権利者からの削除依頼・警告には速やかに対処いたします。お問い合わせは
      <a
        href="/contact"
        class="underline underline-offset-2 hover:text-base-content/60"
        >お問い合わせ・削除申請</a
      >よりご連絡ください。
    </p>
  </footer>
</PageLayout>

<script is:inline define:vars={{ accessToken: safeAccessToken, initialTab: tabQuery }}>
  window.__fusouAccessToken = accessToken;
  window.__fusouInitialTab = initialTab;
</script>

<script>
  import { mountSimulatorTabManager } from "@/components/features/simulator/solid/SimulatorTabManager";

  const root = document.getElementById("simulator-tab-manager-root");
  if (root) {
    const accessToken = (window as any).__fusouAccessToken ?? null;
    const initialTab = (window as any).__fusouInitialTab ?? "fleet";
    mountSimulatorTabManager(root, initialTab, accessToken);
  }
</script>

<style is:global>
  [hidden] {
    display: none !important;
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
</style>
