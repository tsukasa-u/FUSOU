            <h3 class="font-semibold text-sm">基地航空隊</h3>
          </div>
        </div>
        <div class="p-3">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3" id="air-bases"></div>
        </div>
      </section>
      </div>

      <!-- Ship Selection Modal -->
      <dialog id="ship-select-modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box max-w-5xl w-[95vw] h-[85vh] sm:h-[80vh] max-h-[800px] p-0 flex flex-col rounded-t-2xl sm:rounded-xl">
          <div class="px-5 pt-4 pb-3 border-b border-base-200 shrink-0">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-bold text-lg">艦娘を選択</h3>
              <form method="dialog"><button class="btn btn-ghost btn-sm btn-circle">✕</button></form>
            </div>
            <div class="flex gap-2">
              <input type="text" id="ship-modal-search" placeholder="名前・IDで検索..." class="input input-bordered input-sm flex-1" autocomplete="off" />
              <select id="ship-modal-stype" class="select select-bordered select-sm w-32 sm:w-36"><option value="">全艦種</option></select>
            </div>
            <div id="ship-modal-source-tabs" class="tabs tabs-boxed mt-2 hidden">
              <button class="tab tab-sm tab-active" data-source="snapshot">スナップショット</button>
              <button class="tab tab-sm" data-source="master">マスターデータ</button>
            </div>
          </div>
          <div class="flex flex-1 min-h-0">
            <div class="w-20 overflow-y-auto border-r border-base-200 bg-base-200/20 shrink-0 hidden sm:block hide-scrollbar" id="ship-modal-categories"></div>
            <div class="relative flex-1 overflow-y-auto p-2 sm:p-3" id="ship-modal-grid"></div>
            <div class="w-72 xl:w-80 overflow-y-auto p-4 bg-base-200/30 border-l border-base-200 hidden md:block" id="ship-modal-detail">
              <p class="text-sm text-base-content/30 text-center pt-10">艦娘にカーソルを合わせると<br/>詳細が表示されます</p>
            </div>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>

      <!-- Equipment Selection Modal -->
      <dialog id="equip-select-modal" class="modal modal-bottom sm:modal-middle">
        <div class="modal-box max-w-4xl w-[90vw] h-[80vh] sm:h-[75vh] max-h-[700px] p-0 flex flex-col rounded-t-2xl sm:rounded-xl">
          <div class="px-5 pt-4 pb-3 border-b border-base-200 shrink-0">
            <div class="flex items-center justify-between mb-3">
              <h3 class="font-bold text-lg">装備を選択</h3>
              <form method="dialog"><button class="btn btn-ghost btn-sm btn-circle">✕</button></form>
            </div>
            <div class="flex gap-2">
              <input type="text" id="equip-modal-search" placeholder="装備名で検索..." class="input input-bordered input-sm flex-1" autocomplete="off" />
              <select id="equip-modal-type" class="select select-bordered select-sm w-32 sm:w-40"><option value="">全装備種</option></select>
            </div>
            <div id="equip-modal-source-tabs" class="tabs tabs-boxed mt-2 hidden">
              <button class="tab tab-sm tab-active" data-source="snapshot">スナップショット</button>
              <button class="tab tab-sm" data-source="master">マスターデータ</button>
            </div>
          </div>
          <div class="flex flex-1 min-h-0">
            <div class="w-24 overflow-y-auto border-r border-base-200 bg-base-200/20 shrink-0 hidden sm:block hide-scrollbar" id="equip-modal-categories"></div>
            <div class="relative flex-1 overflow-y-auto p-2 sm:p-3" id="equip-modal-grid"></div>
            <div class="w-64 xl:w-72 overflow-y-auto p-4 bg-base-200/30 border-l border-base-200 hidden md:block" id="equip-modal-detail">
              <p class="text-sm text-base-content/30 text-center pt-10">装備にカーソルを合わせると<br/>詳細が表示されます</p>
            </div>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>

      <!-- Load Fleet Modal -->
      <dialog id="load-fleet-modal" class="modal">
