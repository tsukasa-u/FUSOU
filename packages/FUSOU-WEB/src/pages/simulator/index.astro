          <h3 class="font-bold text-lg mb-4">R2から艦隊データを読込</h3>
          <div id="fleet-list-container" class="space-y-2 max-h-80 overflow-y-auto">
            <span class="loading loading-spinner loading-sm"></span>
          </div>
          <div class="modal-action">
            <form method="dialog"><button class="btn btn-ghost btn-sm">閉じる</button></form>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>

      <!-- Save Image Modal -->
      <dialog id="save-image-modal" class="modal">
        <div class="modal-box rounded-xl">
          <h3 class="font-bold text-lg mb-4">画像保存設定</h3>
          <div class="space-y-3 text-sm">
            <div class="form-control">
              <label class="label py-1"><span class="label-text">保存対象</span></label>
              <div class="flex flex-wrap gap-3">
                <label class="label cursor-pointer gap-2 py-0">
