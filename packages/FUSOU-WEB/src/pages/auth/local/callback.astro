---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/Navigation.astro";
import CheckIcon from "../../../components/icons/CheckIcon.astro";
import { createSupabaseServerClient } from "@/utility/supabaseServer";
import { validateRedirectUrl } from "@/utility/security";
import { createEnvContext, getEnv } from "@/server/utils";

const cookies = Astro.cookies;
const runtimeEnv = (Astro.locals as any)?.runtime?.env || {};
const supabase = createSupabaseServerClient(cookies, runtimeEnv);

// For local app flow: read from local auth tokens (sb-local-*)
// These are set by /api/local_auth/callback
const accessToken = cookies.get("sb-local-access-token");
const refreshToken = cookies.get("sb-local-refresh-token");
const providerRefreshToken = cookies.get("sb-local-provider-refresh-token");
const provider = cookies.get("sb-local-provider");
const expiresAtCookie = cookies.get("sb-local-expires-at");

// Get allowed origin using unified env API
const envCtx = createEnvContext({ env: runtimeEnv });
const allowedOrigin = getEnv(envCtx, "PUBLIC_SITE_URL")?.trim()!;

// Get member_id_hash from query params (passed by desktop app during auth)
const memberIdHash = Astro.url.searchParams.get("member_id_hash");

// Detect if request originated from Tauri app
// Check for: app origin parameter, fusou:// referer, or fusou:// deep link indicator
const appOriginParam = Astro.url.searchParams.get("app_origin");
const referer = Astro.request.headers.get("referer") || "";
const isFromTauriApp =
  appOriginParam === "tauri" ||
  referer.includes("fusou://") ||
  appOriginParam !== null; // Any explicit app parameter indicates app context

let error_message: string | null = null;
let return_params: string | null = null;
let set_session_error_flag: boolean = false;
let isDesktopApp: boolean = isFromTauriApp; // Flag to detect desktop app flow
let app_return_url: string | null = null; // URL to return to app

const providerValue = provider?.value ?? "google";

// Provider refresh token is optional. Supabase session tokens are the only
// required credentials for returning auth state to the desktop app.
if (refreshToken?.value && accessToken?.value) {
  try {
    const sessionResult = await supabase.auth.setSession({
      refresh_token: refreshToken.value,
      access_token: accessToken.value,
    });

    if (sessionResult.error) {
      error_message = sessionResult.error.message;
      set_session_error_flag = true;
    } else {
      const userId = sessionResult.data.session?.user.id;
      if (!userId) {
        throw new Error("Supabase session missing user id");
      }

      // Check for member_id_hash conflict BEFORE returning to app
      if (memberIdHash) {
        console.log(
          "[callback] Checking member_id_hash conflict:",
          memberIdHash,
        );
        try {
          const conflictCheckResponse = await fetch(
            Astro.url.origin + "/api/member-lookup/verify-ownership",
            {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Authorization: `Bearer ${accessToken.value}`,
              },
              body: JSON.stringify({
                member_id_hash: memberIdHash,
              }),
            },
          );

          const conflictCheckData = (await conflictCheckResponse.json()) as any;
          console.log("[callback] Conflict check response:", {
            status: conflictCheckResponse.status,
            data: conflictCheckData,
          });

          // If conflict detected (member_id_hash already owned by another user)
          if (
            !conflictCheckResponse.ok &&
            conflictCheckResponse.status === 409
          ) {
            console.log(
              "[callback] CONFLICT DETECTED - redirecting to conflict page",
            );
            // Redirect to conflict resolution page with member_id_hash
            return Astro.redirect(
              `/account/conflict?hash=${encodeURIComponent(memberIdHash)}`,
            );
          }

          if (!conflictCheckResponse.ok) {
            console.warn("Member ID conflict check failed:", conflictCheckData);
            // Proceed anyway - let the app handle any issues
          } else {
            // If migrateable (anonymous owner), call upsert to perform migration
            if (conflictCheckData?.migrateable) {
              console.log(
                "[callback] Anonymous owner detected - performing auto-migration",
              );
              try {
                const upsertResponse = await fetch(
                  Astro.url.origin + "/api/user/member-map/upsert",
                  {
                    method: "POST",
                    headers: {
                      "Content-Type": "application/json",
                      Authorization: `Bearer ${accessToken.value}`,
                    },
                    body: JSON.stringify({ member_id_hash: memberIdHash }),
                  },
                );
                const upsertData = (await upsertResponse.json()) as any;
                if (upsertResponse.ok) {
                  console.log(
                    "[callback] Auto-migration successful:",
                    upsertData?.action,
                  );
                } else {
                  console.error(
                    "[callback] Auto-migration failed:",
                    upsertData,
                  );
                }
              } catch (upsertError) {
                console.error("[callback] Auto-migration error:", upsertError);
              }
            } else {
              console.log("[callback] No conflict - proceeding with auth");
            }
          }
        } catch (checkError) {
          console.error("Error checking member_id_hash conflict:", checkError);
          // Proceed anyway - let the app handle any issues
        }
      } else {
        console.warn(
          "[callback] No member_id_hash provided in query params - skipping conflict check",
        );
      }

      // Build fusou:// return URL for the desktop app.
      // The URL is stored in a short-lived httpOnly cookie so that it is never
      // written into a DOM attribute — only the client-side API endpoint at
      // /api/local_auth/app-redirect reads and consumes it.
      const returnQuery = new URLSearchParams();
      if (providerRefreshToken?.value) {
        returnQuery.set("provider_refresh_token", providerRefreshToken.value);
      }
      returnQuery.set("provider", providerValue);
      returnQuery.set("supabase_access_token", accessToken.value);
      returnQuery.set("supabase_refresh_token", refreshToken.value);
      if (expiresAtCookie?.value) {
        returnQuery.set("expires_at", expiresAtCookie.value);
      }
      return_params = returnQuery.toString();

      const candidateHref = `fusou://auth?${return_params}`;

      // Store for display/manual copy in the UI (no tokens in DOM; only shown
      // when validateRedirectUrl succeeds and user explicitly requests it).
      // Validate the desktop app custom protocol URL
      if (validateRedirectUrl(candidateHref, allowedOrigin)) {
        // Desktop app detected - store the redirect URL in a short-lived cookie.
        if (isFromTauriApp) {
          isDesktopApp = true;
          app_return_url = "/api/local_auth/app-redirect";
          // Store token URL in a 60-second, httpOnly, strict-SameSite cookie.
          // Only /api/local_auth/app-redirect can consume it (single-use).
          cookies.set("sb-app-redirect-url", candidateHref, {
            path: "/api/local_auth/app-redirect",
            httpOnly: true,
            secure: import.meta.env.PROD,
            sameSite: "strict",
            maxAge: 60,
          });
        }
      } else {
        console.error("Invalid return href rejected in local callback");
        error_message = "Invalid redirect URL";
      }

      // Database write is now handled server-side in /api/local_auth/callback.ts
      // No need to upsert here - tokens are already persisted
    }
  } catch (error) {
    error_message = error instanceof Error ? error.message : String(error);
    set_session_error_flag = true;
  }
} else {
  // No tokens present - show warning
  console.warn(
    "Missing required Supabase session cookies. Cannot proceed with authentication.",
  );
  error_message = "Missing required authentication cookies";
  set_session_error_flag = true;
}

// Clean up local app tokens after they've been used
// Prevents tokens from lingering in browser cookies
cookies.delete("sb-local-access-token", { path: "/" });
cookies.delete("sb-local-refresh-token", { path: "/" });
cookies.delete("sb-local-provider-token", { path: "/" });
cookies.delete("sb-local-provider-refresh-token", { path: "/" });
cookies.delete("sb-local-provider", { path: "/" });
cookies.delete("sb-local-expires-at", { path: "/" });
---

<Layout title="Account Setup - Link Game to Social Account">
  <div class="min-h-screen flex items-center justify-center px-4 py-8">
    <div class="w-full max-w-2xl">
      <!-- Header -->
      <div class="bg-base-100 rounded-md p-6 mb-6">
        <div class="flex items-center gap-2">
          <span class="flex-1 flex justify-end">
            <CheckIcon class="w-8 h-8" />
          </span>
          <h1 class="text-center text-2xl font-semibold">Account Setup</h1>
          <span class="flex-1"><div class="h-8 w-8"></div></span>
        </div>
      </div>

      <!-- Step Indicator -->
      <div class="bg-base-100 rounded-md p-6 mb-6">
        <div
          class="flex flex-col sm:flex-row items-center justify-between gap-4 sm:gap-2"
        >
          <!-- Step 1 -->
          <button
            class="step-indicator flex-1 w-full sm:w-auto"
            data-step="1"
            disabled
          >
            <div
              class="flex items-center gap-3 p-3 rounded-lg border-2 transition-all duration-200 step-1-box border-success bg-success/10"
            >
              <div
                class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold step-1-circle bg-success text-success-content"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg
                >
              </div>
              <div class="flex-1 text-left">
                <div class="font-semibold text-sm">Sync Game</div>
                <div class="text-xs opacity-70">Connect account</div>
              </div>
            </div>
          </button>

          <!-- Arrow -->
          <div class="hidden sm:block text-base-content/30">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </div>

          <!-- Step 2 -->
          <button
            class="step-indicator flex-1 w-full sm:w-auto"
            data-step="2"
            disabled
          >
            <div
              class="flex items-center gap-3 p-3 rounded-lg border-2 transition-all duration-200 step-2-box border-success bg-success/10"
            >
              <div
                class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold step-2-circle bg-success text-success-content"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg
                >
              </div>
              <div class="flex-1 text-left">
                <div class="font-semibold text-sm">Link Social</div>
                <div class="text-xs opacity-70">Social account</div>
              </div>
            </div>
          </button>

          <!-- Arrow -->
          <div class="hidden sm:block text-base-content/30">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </div>

          <!-- Step 3 -->
          <button
            class="step-indicator flex-1 w-full sm:w-auto"
            data-step="3"
            disabled
          >
            <div
              class="flex items-center gap-3 p-3 rounded-lg border-2 transition-all duration-200 step-3-box border-success bg-success/10"
            >
              <div
                class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold step-3-circle bg-success text-success-content"
              >
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M5 13l4 4L19 7"></path></svg
                >
              </div>
              <div class="flex-1 text-left">
                <div class="font-semibold text-sm">Complete</div>
                <div class="text-xs opacity-70">Ready to use</div>
              </div>
            </div>
          </button>
        </div>
      </div>

      <!-- Step Content -->
      <div class="bg-base-100 rounded-md p-6">
        <!-- Error State -->
        <div id="error-content" class="step-content hidden">
          <h2 class="text-xl font-bold mb-3 text-error">
            Authentication Failed
          </h2>
          <p class="text-sm text-base-content/70 mb-4">
            We encountered an issue while processing your authentication. Please
            try again.
          </p>

          <div class="alert bg-error/10 border border-error text-sm mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 shrink-0 text-error"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path>
            </svg>
            <div>
              <div class="font-semibold text-error">Error Details</div>
              <div class="leading-snug text-base-content" id="error-message">
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-3">
            <a
              href={`/auth/local/signin${appOriginParam ? `?app_origin=${appOriginParam}` : ""}`}
              class="btn btn-primary w-full border border-primary-content"
            >
              ← Retry Sign-in
            </a>
            <button
              onclick="window.location.href = '/'"
              class="btn btn-ghost w-full border border-base-300"
            >
              Continue as Guest
            </button>
          </div>
        </div>

        <!-- Success State (Step 3) -->
        <div id="success-content" class="step-content hidden">
          <h2 class="text-xl font-bold mb-3">Setup Complete</h2>
          <p class="text-sm text-base-content/70 mb-4">
            Your game account has been successfully linked to your social
            account. You can now access your account from any device.
          </p>

          <div class="alert bg-success/10 border border-success text-sm mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 shrink-0 text-success"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <div class="font-semibold text-success">Account Linked</div>
              <div class="leading-snug text-base-content">
                Your account is ready to use!
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-3">
            <button
              id="dashboard-btn"
              onclick="window.location.href = '/'"
              class="btn btn-primary w-full border border-primary-content"
            >
              → Continue to Dashboard
            </button>
            <a
              id="app-return-link"
              href="fusou://auth?status=success"
              class="btn btn-ghost w-full border border-base-300"
            >
              ← Return to App
            </a>
          </div>
        </div>
      </div>

      <!-- Skip Option -->
      <div class="p-6">
        <p class="text-sm text-base-content/70 mb-3 text-center">
          Your game account and social profile have been securely linked
        </p>
      </div>
    </div>
  </div>

  <Navigation />
</Layout>

<astro-data-callback
  data-error-flag={String(set_session_error_flag)}
  data-error-message={error_message ?? ""}
  data-is-desktop-app={String(isDesktopApp)}
  data-has-app-redirect={String(!!app_return_url)}
>
</astro-data-callback>

<script>
  class AstroDataCallback extends HTMLElement {
    constructor() {
      super();
      const errorFlag = this.dataset.errorFlag === "true";
      const errorMessage = this.dataset.errorMessage || "";
      const isDesktopApp = this.dataset.isDesktopApp === "true";
      const hasAppRedirect = this.dataset.hasAppRedirect === "true";

      window.addEventListener("DOMContentLoaded", () => {
        const errorContent = document.getElementById("error-content");
        const successContent = document.getElementById("success-content");
        const errorMessageEl = document.getElementById("error-message");

        // Update Step 3 indicator based on error state
        const step3Box = document.querySelector(".step-3-box");
        const step3Circle = document.querySelector(".step-3-circle");

        if (errorFlag) {
          // Show error state
          errorContent?.classList.remove("hidden");
          successContent?.classList.add("hidden");

          if (errorMessageEl && errorMessage) {
            errorMessageEl.textContent = errorMessage;
          }

          // Update Step 3 to error state
          if (step3Box && step3Circle) {
            step3Box.className =
              "flex items-center gap-3 p-3 rounded-lg border-2 transition-all duration-200 step-3-box border-error bg-error/10";
            step3Circle.className =
              "shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold step-3-circle bg-error text-error-content";
            step3Circle.innerHTML =
              '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>';
          }

          // On error, do not auto-redirect to the app with any token URL.
          // The app-redirect cookie has already expired or been consumed.
          // The user can retry sign-in instead.
        } else {
          // Show success state (Step 3)
          errorContent?.classList.add("hidden");
          successContent?.classList.remove("hidden");

          // Update Step 3 to success state
          if (step3Box && step3Circle) {
            step3Box.className =
              "flex items-center gap-3 p-3 rounded-lg border-2 transition-all duration-200 step-3-box border-success bg-success/10";
            step3Circle.className =
              "shrink-0 w-8 h-8 rounded-full flex items-center justify-center font-bold step-3-circle bg-success text-success-content";
            step3Circle.innerHTML =
              '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>';
          }

          // Set manual return-to-app link (fetches actual redirect from API).
          const appReturnLink = document.getElementById("app-return-link");
          if (appReturnLink) {
            if (hasAppRedirect) {
              appReturnLink.setAttribute("href", "/api/local_auth/app-redirect");
            } else {
              appReturnLink.setAttribute("href", "fusou://auth?status=success");
            }
          }

          // Switch primary accent depending on app vs web
          const dashboardBtn = document.getElementById("dashboard-btn");
          if (dashboardBtn && appReturnLink) {
            if (isDesktopApp) {
              // App is primary action
              dashboardBtn.classList.remove(
                "btn-primary",
                "border-primary-content",
              );
              dashboardBtn.classList.add("btn-ghost", "border-base-300");

              appReturnLink.classList.remove("btn-ghost", "border-base-300");
              appReturnLink.classList.add(
                "btn-primary",
                "border-primary-content",
              );
            } else {
              // Web is primary action
              dashboardBtn.classList.add(
                "btn-primary",
                "border-primary-content",
              );
              dashboardBtn.classList.remove("btn-ghost", "border-base-300");

              appReturnLink.classList.add("btn-ghost", "border-base-300");
              appReturnLink.classList.remove(
                "btn-primary",
                "border-primary-content",
              );
            }
          }

          // Auto-redirect to app on success via the one-time server endpoint.
          // Tokens are in an httpOnly cookie consumed by /api/local_auth/app-redirect,
          // so they are never exposed in JS scope.
          if (isDesktopApp && hasAppRedirect) {
            setTimeout(() => {
              window.location.href = "/api/local_auth/app-redirect";
            }, 1500); // 1.5 second delay to show success message
          }
        }
      });
    }
  }

  customElements.define("astro-data-callback", AstroDataCallback);
</script>
