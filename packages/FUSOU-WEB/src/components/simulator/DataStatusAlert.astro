---
/**
 * Shared master-data loading status notification bar.
 * Used by simulator/index.astro and simulator/details.astro.
 *
 * JS-facing API (via data-loader.ts updateDataStatus()):
 *   - #data-status              outer element – hidden/visible controlled by JS
 *   - #data-status-icon-info | #data-status-icon-success | #data-status-icon-warning
 *                               exactly one shown at a time
 *   - #data-status-text         main text content (e.g. "マスターデータ読込済み — …")
 *   - #data-status-master-meta  sub-line: master data period/revision (hidden when unavailable)
 *   - #data-status-synergy-meta sub-line: equipment synergy data period/version (hidden when unavailable)
 *   - #data-status-details      detailed table load results (collapsible)
 *   - #data-status-details-toggle button to toggle details visibility
 */

interface Props {
  /** Tailwind margin-bottom class, e.g. "mb-4" or "mb-5". */
  mb?: string;
  /** Initial text before JS updates it. */
  initialText?: string;
  /** If true the element starts hidden until JS reveals it. */
  startHidden?: boolean;
  /** If true, show details toggle button. */
  showDetailsToggle?: boolean;
}

const {
  mb = "mb-4",
  initialText = "マスターデータを読込中...",
  startHidden = false,
  showDetailsToggle = true,
} = Astro.props;
---

<div
  id="data-status"
  data-testid="master-data-status"
  class:list={[
    "alert",
    "alert-info",
    "text-sm",
    "py-2",
    mb,
    { hidden: startHidden },
  ]}
>
  <!-- info / loading icon (shown by default) -->
  <svg
    id="data-status-icon-info"
    class="shrink-0 w-5 h-5 stroke-current text-info"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="2 2 22 22"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 12c0 4.418 3.582 8 8 8s8-3.582 8-8-3.582-8-8-8-8 3.582-8 8Zm8-4v4"
    ></path>
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 16h.01"></path>
  </svg>

  <!-- success / check icon -->
  <svg
    id="data-status-icon-success"
    class="shrink-0 w-5 h-5 stroke-current text-success hidden"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
  </svg>

  <!-- warning / triangle icon -->
  <svg
    id="data-status-icon-warning"
    class="shrink-0 w-5 h-5 stroke-current text-warning hidden"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
    ></path>
  </svg>

  <span class="flex flex-col leading-tight gap-0.5 flex-1">
    <span class="flex items-center justify-between gap-2">
      <span id="data-status-text" class="text-sm">{initialText}</span>
      {showDetailsToggle && (
        <button
          id="data-status-details-toggle"
          class="btn btn-xs btn-ghost"
          title="詳細ロード結果を表示/非表示"
          style="min-height: auto; padding: 0.25rem 0.5rem; display: none;"
        >
          詳細
        </button>
      )}
    </span>
    <span id="data-status-master-meta" class="text-[11px] opacity-70 hidden"
    ></span>
    <span id="data-status-synergy-meta" class="text-[11px] opacity-70 hidden"
    ></span>
    <div
      id="data-status-details"
      class="text-[11px] mt-2 flex flex-col gap-1 hidden"
    ></div>
  </span>
</div>
