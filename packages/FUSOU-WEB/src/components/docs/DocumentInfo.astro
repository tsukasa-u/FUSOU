---
import { isSafeImageUrl } from "@/utility/security";

const { lastUpdated, contributors } = Astro.props;

const safeExternalHttpUrl = (value?: string): string | undefined => {
  if (!value) return undefined;
  try {
    const parsed = new URL(value);
    if (parsed.protocol !== "https:" && parsed.protocol !== "http:") {
      return undefined;
    }
    return parsed.toString();
  } catch {
    return undefined;
  }
};
---

{
  lastUpdated && (
    <div class="text-md text-gray-600">
      Last updated: &nbsp;{" "}
      {new Date(lastUpdated).toLocaleDateString(undefined, {
        year: "numeric",
        month: "short",
        day: "numeric",
      })}
    </div>
  )
}
{
  contributors && contributors.length > 0 && (
    <div class="my-4 flex">
      <h3 class="text-md text-gray-600 content-center">
        Contributors: &nbsp;&nbsp;
      </h3>
      <ul class="list-none p-0 m-0 flex flex-row gap-4 flex-wrap">
        {contributors.map(
          (contributor: {
            data: {
              github_avatar?: string;
              github_username: string;
              github_url?: string;
            };
          }) => {
            const safeAvatarUrl =
              contributor.data.github_avatar &&
              isSafeImageUrl(contributor.data.github_avatar)
                ? contributor.data.github_avatar
                : undefined;
            const safeProfileUrl = safeExternalHttpUrl(
              contributor.data.github_url,
            );

            return (
              <li class="flex items-center">
                {safeAvatarUrl ? (
                <img
                  src={safeAvatarUrl}
                  alt={contributor.data.github_username}
                  class="size-8 rounded-full mr-2"
                />
              ) : (
                <div class="size-8 rounded-full bg-gray-300 flex items-center justify-center text-gray-600 mr-2">
                  {contributor.data.github_username.charAt(0).toUpperCase()}
                </div>
              )}
              {safeProfileUrl ? (
                <a
                  href={safeProfileUrl}
                  class="text-md text-blue-500 hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {contributor.data.github_username}
                </a>
              ) : (
                <span class="text-md text-gray-800">
                  {contributor.data.github_username}
                </span>
              )}
              </li>
            );
          }
        )}
      </ul>
    </div>
  )
}
