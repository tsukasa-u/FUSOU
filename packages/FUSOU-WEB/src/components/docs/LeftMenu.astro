---
import type { MarkdownInstance } from "astro";
import { compareSegments } from "@/utils/page_sorter";

const rawPostsGlobResult = import.meta.glob("@docs/**/*.md", {
  eager: true,
});
const rawPosts = Object.values(
  rawPostsGlobResult
).reverse() as MarkdownInstance<Record<string, any>>[];

const normalizeSlug = (value: string | undefined) =>
  (value ?? "").replace(/^\/+|\/+$/g, "").replace(/^docs\//, "");

const formatSegment = (segment: string) =>
  segment
    .split(/[-_]/g)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");

type Posts = {
  slug: string;
  segments: string[];
  title: string;
  url: string;
}[];
const posts = rawPosts
  .map((post) => {
    const slug = normalizeSlug(post.frontmatter?.slug);
    const segments = slug.split("/").filter(Boolean);
    if (segments.length === 0) return null;

    return {
      slug,
      segments,
      title: post.frontmatter?.title ?? formatSegment(segments.at(-1)!),
      url: `/docs/${slug}`,
    };
  })
  .filter(Boolean) as Posts;

const postsWithSchema: Posts = [
  {
    slug: "schema/api-schema-explorer",
    segments: ["schema", "api-schema-explorer"],
    title: "API Schema Explorer",
    url: "/docs/api-schema",
  },
  ...posts,
];

type MenuNode = {
  segment: string;
  title: string;
  url?: string;
  children: Map<string, MenuNode>;
};

type MenuEntry = {
  title: string;
  url?: string;
  children: MenuEntry[];
};

const root = new Map<string, MenuNode>();

for (const entry of postsWithSchema) {
  let current = root;
  entry.segments.forEach((segment, index) => {
    const isLeaf = index === entry.segments.length - 1;
    if (!current.has(segment)) {
      current.set(segment, {
        segment,
        title: isLeaf ? entry.title : formatSegment(segment),
        url: isLeaf ? entry.url : undefined,
        children: new Map(),
      });
    } else if (isLeaf) {
      const node = current.get(segment)!;
      node.title = entry.title;
      node.url = entry.url;
    }
    current = current.get(segment)!.children;
  });
}

const mapToArray = (nodeMap: Map<string, MenuNode>): MenuEntry[] =>
  Array.from(nodeMap.values())
    .sort(compareSegments)
    .map((node: MenuNode): MenuEntry => ({
      title: node.title,
      url: node.url,
      children: mapToArray(node.children),
    }));

const menuTree = mapToArray(root);
const currentPath = Astro.url.pathname;

const escapeHtml = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");

const sanitizeDocsUrl = (value: string | undefined): string | null => {
  if (!value || !value.startsWith("/docs/")) return null;
  const slug = value.slice("/docs/".length);
  const safeSlug = slug
    .split("/")
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join("/");
  return safeSlug ? `/docs/${safeSlug}` : "/docs";
};

const renderMenuHtml = (nodes: MenuEntry[]): string =>
  nodes
    .map((node: MenuEntry) => {
      const safeUrl = sanitizeDocsUrl(node.url);
      const isActive = safeUrl === currentPath;
      const children = node.children.length
        ? `<ul class="ml-3 pl-3 space-y-2">${renderMenuHtml(
            node.children
          )}</ul>`
        : "";
      const label = safeUrl
        ? `<a href="${escapeHtml(safeUrl)}" class="docs-left-link block rounded-lg px-2 py-1 text-sm font-medium transition-all ${
            isActive
              ? "bg-primary/15 text-primary"
              : "text-base-content hover:bg-sky-500/10 hover:text-sky-500 hover:underline hover:translate-x-0.5"
          }">${escapeHtml(node.title)}</a>`
        : `<details open><summary class="text-sm font-semibold text-base-content/80 tracking-wide">${escapeHtml(node.title)}</summary>${
            children
          }</details>`;
      return `<li class="my-px">${label}</li>`;
    })
    .join("");

const menuHtml = renderMenuHtml(menuTree);
---

<div class="sticky top-20">
  <div class="max-h-[calc(100vh-6rem)] overflow-y-auto pr-2">
    <h2 class="text-xl font-bold mb-1">Documentation</h2>
    <p class="text-xs text-base-content/65 mb-3">Browse by section</p>
    <nav aria-label="Documentation sections">
      <ul class="menu bg-base-100 rounded-box w-full p-2" set:html={menuHtml} />
    </nav>
  </div>
</div>

<style>
  .docs-left-link:hover {
    text-decoration-thickness: 2px;
    text-underline-offset: 2px;
  }
</style>
