---
const filled: boolean = Astro.props.filled;
const css_filled = filled ? "bg-navbar" : "bg-base-100";
---

<div
  class=`navbar border-base-300 border-b z-50 fixed top-0 left-0 ${css_filled}`
>
  <div class="flex w-full max-w-[1440px] mx-auto px-4 sm:px-8 py-1 flex-wrap items-center gap-1 sm:gap-2">
    <div class="flex items-center gap-1 min-w-0">
      <a class="btn btn-ghost text-xl" href="/">FUSOU</a>
      <div class="tooltip tooltip-bottom" data-tip="GitHub">
        <a
          class="btn btn-ghost"
          href="https://github.com/tsukasa-u/FUSOU"
          aria-label="GitHub Repository"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 448 512"
            fill="currentColor"
            stroke="currentColor"
            ><!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
            <path
              d="M448 96c0-35.3-28.7-64-64-64H64C28.7 32 0 60.7 0 96V416c0 35.3 28.7 64 64 64H384c35.3 0 64-28.7 64-64V96zM265.8 407.7c0-1.8 0-6 .1-11.6c.1-11.4 .1-28.8 .1-43.7c0-15.6-5.2-25.5-11.3-30.7c37-4.1 76-9.2 76-73.1c0-18.2-6.5-27.3-17.1-39c1.7-4.3 7.4-22-1.7-45c-13.9-4.3-45.7 17.9-45.7 17.9c-13.2-3.7-27.5-5.6-41.6-5.6s-28.4 1.9-41.6 5.6c0 0-31.8-22.2-45.7-17.9c-9.1 22.9-3.5 40.6-1.7 45c-10.6 11.7-15.6 20.8-15.6 39c0 63.6 37.3 69 74.3 73.1c-4.8 4.3-9.1 11.7-10.6 22.3c-9.5 4.3-33.8 11.7-48.3-13.9c-9.1-15.8-25.5-17.1-25.5-17.1c-16.2-.2-1.1 10.2-1.1 10.2c10.8 5 18.4 24.2 18.4 24.2c9.7 29.7 56.1 19.7 56.1 19.7c0 9 .1 21.7 .1 30.6c0 4.8 .1 8.6 .1 10c0 4.3-3 9.5-11.5 8C106 393.6 59.8 330.8 59.8 257.4c0-91.8 70.2-161.5 162-161.5s166.2 69.7 166.2 161.5c.1 73.4-44.7 136.3-110.7 158.3c-8.4 1.5-11.5-3.7-11.5-8zm-90.5-54.8c-.2-1.5 1.1-2.8 3-3.2c1.9-.2 3.7 .6 3.9 1.9c.3 1.3-1 2.6-3 3c-1.9 .4-3.7-.4-3.9-1.7zm-9.1 3.2c-2.2 .2-3.7-.9-3.7-2.4c0-1.3 1.5-2.4 3.5-2.4c1.9-.2 3.7 .9 3.7 2.4c0 1.3-1.5 2.4-3.5 2.4zm-14.3-2.2c-1.9-.4-3.2-1.9-2.8-3.2s2.4-1.9 4.1-1.5c2 .6 3.3 2.1 2.8 3.4c-.4 1.3-2.4 1.9-4.1 1.3zm-12.5-7.3c-1.5-1.3-1.9-3.2-.9-4.1c.9-1.1 2.8-.9 4.3 .6c1.3 1.3 1.8 3.3 .9 4.1c-.9 1.1-2.8 .9-4.3-.6zm-8.5-10c-1.1-1.5-1.1-3.2 0-3.9c1.1-.9 2.8-.2 3.7 1.3c1.1 1.5 1.1 3.3 0 4.1c-.9 .6-2.6 0-3.7-1.5zm-6.3-8.8c-1.1-1.3-1.3-2.8-.4-3.5c.9-.9 2.4-.4 3.5 .6c1.1 1.3 1.3 2.8 .4 3.5c-.9 .9-2.4 .4-3.5-.6zm-6-6.4c-1.3-.6-1.9-1.7-1.5-2.6c.4-.6 1.5-.9 2.8-.4c1.3 .7 1.9 1.8 1.5 2.6c-.4 .9-1.7 1.1-2.8 .4z"
            ></path></svg
          >
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Rust Docs">
        <a
          class="btn btn-ghost"
          href="https://tsukasa-u.github.io/FUSOU/"
          aria-label="Rust Crate Document"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            ,
            height="24"
            viewBox="0 0 576 512"
            fill="currentColor"
            stroke="currentColor"
            ><!--!Font Awesome Free 6.7.2 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
            <path
              d="M290.8 48.6l78.4 29.7L288 109.5 206.8 78.3l78.4-29.7c1.8-.7 3.8-.7 5.7 0zM136 92.5l0 112.2c-1.3 .4-2.6 .8-3.9 1.3l-96 36.4C14.4 250.6 0 271.5 0 294.7L0 413.9c0 22.2 13.1 42.3 33.5 51.3l96 42.2c14.4 6.3 30.7 6.3 45.1 0L288 457.5l113.5 49.9c14.4 6.3 30.7 6.3 45.1 0l96-42.2c20.3-8.9 33.5-29.1 33.5-51.3l0-119.1c0-23.3-14.4-44.1-36.1-52.4l-96-36.4c-1.3-.5-2.6-.9-3.9-1.3l0-112.2c0-23.3-14.4-44.1-36.1-52.4l-96-36.4c-12.8-4.8-26.9-4.8-39.7 0l-96 36.4C150.4 48.4 136 69.3 136 92.5zM392 210.6l-82.4 31.2 0-89.2L392 121l0 89.6zM154.8 250.9l78.4 29.7L152 311.7 70.8 280.6l78.4-29.7c1.8-.7 3.8-.7 5.7 0zm18.8 204.4l0-100.5L256 323.2l0 95.9-82.4 36.2zM421.2 250.9c1.8-.7 3.8-.7 5.7 0l78.4 29.7L424 311.7l-81.2-31.1 78.4-29.7zM523.2 421.2l-77.6 34.1 0-100.5L528 323.2l0 90.7c0 3.2-1.9 6-4.8 7.3z"
            ></path></svg
          >
        </a>
      </div>
    </div>
    <div class="flex items-center gap-1 sm:gap-2 ml-auto w-full sm:w-auto justify-end">
      <div class="tooltip tooltip-bottom sm:tooltip-bottom" data-tip="Battles">
        <a class="btn btn-ghost btn-sm" href="/battles" aria-label="Battles">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.3 1.046a.75.75 0 011.06 0l6.594 6.594a.75.75 0 010 1.06l-2.122 2.122a.75.75 0 01-1.06 0l-5.534-5.534a.75.75 0 010-1.06L11.3 1.046zM9.177 5.29a.75.75 0 010 1.06l-6.93 6.93a2.25 2.25 0 000 3.182l1.06 1.06a2.25 2.25 0 003.182 0l6.93-6.93a.75.75 0 00-1.06-1.06L5.429 16.46a.75.75 0 01-1.06 0l-1.06-1.06a.75.75 0 010-1.06l6.93-6.93a.75.75 0 000-1.06.75.75 0 00-1.06 0z" clip-rule="evenodd" /></svg>
          <span class="hidden sm:inline">Battles</span>
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Simulator">
        <a class="btn btn-ghost btn-sm" href="/simulator" aria-label="Simulator">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M2 4.75A1.75 1.75 0 013.75 3h12.5A1.75 1.75 0 0118 4.75v7.5A1.75 1.75 0 0116.25 14H3.75A1.75 1.75 0 012 12.25v-7.5z" /><path d="M6 16.5a.75.75 0 01.75-.75h6.5a.75.75 0 010 1.5h-6.5A.75.75 0 016 16.5z" /></svg>
          <span class="hidden sm:inline">Simulator</span>
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Docs">
        <a class="btn btn-ghost btn-sm" href="/docs" aria-label="Docs">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M4.25 2A2.25 2.25 0 002 4.25v11.5A2.25 2.25 0 004.25 18h11.5A2.25 2.25 0 0018 15.75V6.561a2.25 2.25 0 00-.659-1.591l-2.31-2.31A2.25 2.25 0 0013.44 2H4.25z" /><path d="M10 6.5a.75.75 0 01.75.75v5a.75.75 0 01-1.5 0v-5A.75.75 0 0110 6.5zM10 14.5a.875.875 0 100 1.75.875.875 0 000-1.75z" /></svg>
          <span class="hidden sm:inline">Docs</span>
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Contact">
        <a class="btn btn-ghost btn-sm" href="/contact" aria-label="Contact">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M2.94 6.34A2 2 0 014.5 5h11a2 2 0 011.56.75L10 10.6 2.94 5.75A2 2 0 012.94 6.34z" /><path d="M2 8.11V14a2 2 0 002 2h12a2 2 0 002-2V8.11l-7.4 5.8a1 1 0 01-1.24 0L2 8.11z" /></svg>
          <span class="hidden sm:inline">Contact</span>
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Sign In">
        <a class="btn btn-ghost btn-sm" href="/dashboard" aria-label="Sign In">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a5 5 0 00-5 5v1.256A4.5 4.5 0 003.5 12v3A2.5 2.5 0 006 17.5h8a2.5 2.5 0 002.5-2.5v-3A4.5 4.5 0 0015 8.256V7a5 5 0 00-5-5z" /></svg>
          <span class="hidden sm:inline">Sign In</span>
        </a>
      </div>
      <div class="tooltip tooltip-bottom" data-tip="Download">
        <a class="btn btn-ghost btn-sm" href="/download" aria-label="Download">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a.75.75 0 01.75.75v7.19l1.72-1.72a.75.75 0 111.06 1.06l-3 3a.75.75 0 01-1.06 0l-3-3a.75.75 0 111.06-1.06l1.72 1.72V2.75A.75.75 0 0110 2z" /><path d="M3.5 13.5a.75.75 0 01.75.75v1a1 1 0 001 1h9.5a1 1 0 001-1v-1a.75.75 0 011.5 0v1A2.5 2.5 0 0115.25 17h-9.5A2.5 2.5 0 013.25 15.25v-1a.75.75 0 01.75-.75z" /></svg>
          <span class="hidden sm:inline">Download</span>
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .bg-navbar {
    background-color: color(from var(--color-base-100) srgb r g b / 0.6);
  }
</style>
