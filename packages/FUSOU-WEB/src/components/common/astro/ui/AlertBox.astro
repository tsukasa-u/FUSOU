---
import InfoIcon from "@/components/common/astro/icons/InfoIcon.astro";
import WarningIcon from "@/components/common/astro/icons/WarningIcon.astro";
import CheckIcon from "@/components/common/astro/icons/CheckIcon.astro";

interface Props {
  type: "info" | "success" | "warning" | "error";
  title: string;
  class?: string;
}

const { type, title, class: className = "" } = Astro.props;

const typeStyles = {
  info: {
    alertClass: "alert-info",
    iconClass: "text-info",
    titleClass: "text-base-content",
  },
  success: {
    alertClass: "alert-success",
    iconClass: "text-success",
    titleClass: "text-success",
  },
  warning: {
    alertClass: "alert-warning",
    iconClass: "text-warning",
    titleClass: "text-warning",
  },
  error: {
    alertClass: "alert-error",
    iconClass: "text-error",
    titleClass: "text-error",
  },
};

const styles = typeStyles[type];
const IconComponent =
  type === "info" ? InfoIcon : type === "success" ? CheckIcon : WarningIcon;
---

<div class={`alert ${styles.alertClass} flex items-start gap-3 ${className}`}>
  <IconComponent class={`w-6 h-6 shrink-0 ${styles.iconClass}`} />
  <div>
    <div class={`font-semibold ${styles.titleClass}`}>{title}</div>
    <div class="leading-snug">
      <slot />
    </div>
  </div>
</div>
