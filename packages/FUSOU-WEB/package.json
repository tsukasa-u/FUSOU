{
  "name": "fusou-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenvx run -fk ../.env.keys -f .env --verbose --overload -- astro dev",
    "dev:workers": "dotenvx run -fk ../.env.keys -f .env --verbose --overload -- wrangler dev",
    "generate:rust-data": "cd ../kc_api && bash scripts/generate-schemas.sh && cargo test -p kc-api-dto test_struct_dependency_syn -- --nocapture && cargo test -p kc-api-database test_database_dependency_syn -- --nocapture",
    "generate:graph-data": "node scripts/convert-dot-to-reactflow.mjs && node scripts/convert-schema-to-reactflow.mjs",
    "check:security:dom": "node scripts/check-security-dom.mjs",
    "generate:all": "pnpm run generate:rust-data && pnpm run generate:graph-data",
    "build": "pnpm --filter @fusou/avro-wasm run build && pnpm run generate:all && pnpm run check:security:dom && astro check && dotenvx run -fk ../.env.keys -f .env --verbose --overload -- astro build",
    "build.no.keys": "pnpm --filter @fusou/avro-wasm run build && export PATH=\"$HOME/.cargo/bin:$PATH\" && pnpm run generate:all && pnpm run check:security:dom && astro check && dotenvx run -f .env --verbose --overload -- astro build",
    "deploy": "pnpm run build && echo '_worker.js' > dist/.assetsignore && wrangler deploy",
    "preview": "dotenvx run -fk ../.env.keys -f .env --verbose --overload -- astro preview",
    "astro": "astro",
    "gen:licenses": "node ../../scripts/generate-licenses.js",
    "verify:battle-data": "node scripts/verify-battle-data.mjs",
    "test:battle-data": "vitest run src/server/routes/__tests__/battle_data.integration.test.ts",
    "e2e:simulator": "playwright test -c playwright.config.ts e2e/simulator.spec.ts",
    "e2e:simulator:smoke": "playwright test -c playwright.config.ts e2e/simulator.smoke.spec.ts",
    "e2e:simulator:headed": "playwright test -c playwright.config.ts e2e/simulator.spec.ts --headed",
    "e2e:simulator:ui": "playwright test -c playwright.config.ts e2e/simulator.spec.ts --ui",
    "e2e:simulator:ci": "playwright test -c playwright.config.ts e2e/simulator.spec.ts --reporter=list",
    "e2e:simulator:ci:smoke": "playwright test -c playwright.config.ts e2e/simulator.smoke.spec.ts --reporter=list",
    "e2e:simulator:install": "playwright install chromium",
    "seed:master-data": "node scripts/seed-local-master-data.mjs",
    "seed:master-data:all": "node scripts/seed-local-master-data.mjs --all",
    "seed:fleet-data": "node scripts/seed-local-fleet-data.mjs --all",
    "seed:battle-data": "node scripts/seed-local-battle-data.mjs --period latest",
    "seed:battle-data:all": "node scripts/seed-local-battle-data.mjs --period all",
    "sync:banners": "node scripts/sync-remote-d1-banners.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.5",
    "@dagrejs/dagre": "^2.0.4",
    "@duckdb/duckdb-wasm": "1.29.1-dev132.0",
    "@duckdb/node-api": "1.2.2-alpha.18",
    "@fusou/avro-wasm": "workspace:*",
    "@nanostores/persistent": "^1.2.0",
    "@nanostores/solid": "^1.1.1",
    "@supabase/supabase-js": "2.86.0",
    "@xyflow/react": "^12.10.0",
    "apache-arrow": "^20.0.0",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.5",
    "elkjs": "^0.11.0",
    "hono": "^4.12.4",
    "html-to-image": "^1.11.13",
    "jose": "^6.1.2",
    "katex": "^0.16.44",
    "nanostores": "^1.1.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-virtuoso": "^4.15.0",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "remark-math": "^6.0.0",
    "shared-ui": "workspace:*",
    "solid-chartjs": "^1.3.11",
    "solid-js": "^1.9.10",
    "uuid": "^9.0.0",
    "virtua": "^0.41.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/solid-js": "^6.0.1",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@dotenvx/dotenvx": "^1.51.1",
    "@faker-js/faker": "^9.9.0",
    "@msgpack/msgpack": "^3.1.3",
    "@playwright/test": "^1.57.0",
    "@r4ai/remark-callout": "^0.6.2",
    "@tailwindcss/vite": "^4.1.17",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.2",
    "astro-icon": "^1.1.5",
    "baseline-browser-mapping": "^2.10.10",
    "msgpackr": "^1.11.8",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "wrangler": "^4.78.0"
  }
}
