{
  "name": "kcs-script-tools",
  "version": "1.0.0",
  "private": true,
  "description": "KanColle game script analysis tools",
  "scripts": {
    "generate:latest": "bash scripts/generate-synergy-latest.sh && pnpm run upload:local",
    "generate:latest:noupload": "bash scripts/generate-synergy-latest.sh",
    "generate:latest:nofilter": "bash scripts/generate-synergy-latest.sh --no-ast-candidate-ships && pnpm run upload:local",
    "generate:latest:nofilter:noupload": "bash scripts/generate-synergy-latest.sh --no-ast-candidate-ships",
    "generate:latest:600-650": "bash scripts/generate-synergy-latest.sh --ship-range 600-650 && pnpm run upload:local",
    "generate:latest:600-650:noupload": "bash scripts/generate-synergy-latest.sh --ship-range 600-650",
    "generate:all": "bash scripts/generate-synergy-all.sh",
    "scan:ast": "node scripts/core/scan-ast.js",
    "verify:best:600-650": "bash scripts/verify-best-600-650.sh",
    "upload:remote": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production",
    "upload:remote:dry": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production --dry-run",
    "upload:remote:force": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production --force",
    "upload:local": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development",
    "upload:local:force": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --force",
    "upload:local:dry": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --dry-run",
    "upload:local:no-br": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --no-br",
    "upload:local:no-br:force": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --no-br --force"
  },
  "dependencies": {
    "jsdom": "^25.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "isolated-vm": "^7.0.0",
    "webcrack": "^2.0.0"
  }
}
