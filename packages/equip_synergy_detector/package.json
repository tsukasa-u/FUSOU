{
  "name": "kcs-script-tools",
  "version": "1.0.0",
  "private": true,
  "description": "KanColle game script analysis tools",
  "scripts": {
    "deobfuscate": "node scripts/deobfuscate.js",
    "scan": "node scripts/scan.js",
    "scan:main": "node scripts/scan.js --main",
    "scan:deterministic": "node scripts/scan.js",
    "scan:volatile": "node scripts/scan.js --volatile-generated",
    "scan:upload": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node scripts/scan-upload.mjs --env production",
    "scan:upload:dry": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node scripts/scan-upload.mjs --env production --dry-run",
    "upload:only": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production --file ./output/slot_item_effects.json",
    "upload:only:dry": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production --file ./output/slot_item_effects.json --dry-run",
    "upload:only:force": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env production --file ./output/slot_item_effects.json --force",
    "upload:local": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --file ./output/slot_item_effects.json",
    "upload:local:dry": "dotenvx run -fk ../.env.keys -f ../FUSOU-WEB/.env -- node ../FUSOU-WEB/scripts/upload-synergy.mjs --env development --file ./output/slot_item_effects.json --dry-run",
    "start": "node scripts/run.js",
    "start:main": "node scripts/run.js --main",
    "repl": "node scripts/run.js --repl",
    "sloteffect": "node scripts/run-sloteffect.js"
  },
  "dependencies": {
    "jsdom": "^25.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.59.1",
    "webcrack": "^2.0.0"
  }
}
